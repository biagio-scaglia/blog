---
import { Mail, Phone } from 'lucide-astro';
import { Image } from 'astro:assets';
import myAvatar from '../assets/immagine.jpeg';
---

<section class="hero galaxy-card">
  <div class="hero-content">
    <div class="hero-text">
      <h1 class="heading-galaxy text-gradient">Biagio<br/>Scaglia</h1>
      <h2 class="role">Fullstack Developer & UI Designer</h2>
      <p class="bio">
        Sviluppatore software, UI Designer e Content Creator. Biagio Scaglia unisce l'architettura solida del backend .NET alla magia del frontend, con un'anima nerd dedicata all'analisi del game design e della tecnologia moderna.
      </p>
      
      <div class="contact-info">
        <a href="tel:+393513150134" class="contact-link">
          <Phone size={18} />
          <span>+39 351 315 0134</span>
        </a>
        <a href="mailto:biagio.scaglia01@gmail.com" class="contact-link">
          <Mail size={18} />
          <span>biagio.scaglia01@gmail.com</span>
        </a>
      </div>
      
      <div class="hero-actions">
        <a href="#competenze" class="galaxy-button primary">Le mie competenze</a>
        <a href="/blog" class="galaxy-button secondary">Leggi il Blog</a>
      </div>
    </div>
    
    <div class="hero-image-container">
      <div class="avatar-glow">
        <Image src={myAvatar} alt="Biagio Scaglia" class="avatar-img" loading="eager" fetchpriority="high" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    /* Adjusted mobile padding to avoid overflow */
    padding: 2.5rem 1.5rem;
    margin-bottom: 4rem;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    width: 100%;
  }
  
  .hero::after {
    content: '';
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 150%;
    background: radial-gradient(ellipse at center, rgba(94, 23, 235, 0.15) 0%, transparent 70%);
    z-index: -1;
    transform: rotate(15deg);
    pointer-events: none;
  }
  
  .hero-content {
    display: flex;
    flex-direction: column-reverse;
    gap: 3.5rem;
  }
  
  @media (min-width: 768px) {
    .hero {
      padding: 4rem;
    }
    
    .hero-content {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
    
    .hero-text {
      flex: 1.5;
      padding-right: 2rem;
    }
    
    .hero-image-container {
      flex: 1;
      display: flex;
      justify-content: flex-end;
    }
  }
  
  .heading-galaxy {
    /* Smaller baseline font to fit 320px screens perfectly */
    font-size: 3.25rem;
    line-height: 1.05;
    margin-bottom: 0.5rem;
    word-break: break-word;
    hyphens: auto;
  }
  
  @media (min-width: 768px) {
    .heading-galaxy {
      font-size: 5.5rem;
    }
  }
  
  .role {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--text-secondary);
    margin-bottom: 1.5rem;
    letter-spacing: 0.5px;
  }
  
  .bio {
    font-size: 1.15rem;
    line-height: 1.8;
    color: var(--text-primary);
    margin-bottom: 2.5rem;
    max-width: 650px;
    font-weight: 300;
  }
  
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 3rem;
  }
  
  @media (min-width: 600px) {
    .contact-info {
      flex-direction: row;
      flex-wrap: wrap; /* Enforce wrapping of the group, not the item text */
      gap: 2rem;
    }
  }
  
  .contact-link {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    font-weight: 400;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color 0.3s ease;
    white-space: nowrap; /* CRITICAL: Prevents phone number from breaking on spaces */
  }
  
  .contact-link:hover {
    color: var(--nebula-cyan);
  }
  
  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }
  
  .hero-image-container {
    display: flex;
    justify-content: center;
    position: relative;
  }
  
  .avatar-glow {
    position: relative;
    border-radius: 50%;
    padding: 8px; /* Slightly thinner padding */
    background: linear-gradient(135deg, rgba(0, 240, 255, 0.4), rgba(255, 0, 127, 0.4));
    box-shadow: 0 0 30px rgba(94, 23, 235, 0.4);
    animation: float 6s ease-in-out infinite;
    /* Enforce STRICT size on the wrapper */
    width: 200px;
    height: 200px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  @media (min-width: 768px) {
    .avatar-glow {
      width: 280px;
      height: 280px;
    }
  }
  
  @keyframes float {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-15px); }
    100% { transform: translateY(0px); }
  }
  
  /* Target the img directly inside the glow to bypass Astro scoped CSS issues */
  .avatar-glow img {
    border-radius: 50%;
    display: block;
    background: var(--galaxy-bg);
    border: 4px solid var(--galaxy-dark);
    object-fit: cover !important;
    width: 100% !important;
    height: 100% !important;
    margin: 0;
    padding: 0;
  }
</style>
