---
import { getCollection } from 'astro:content';
import Window from './Window.astro';
import MoodWidget from './MoodWidget.astro';
import MusicPlayer from './MusicPlayer.astro';
import ArchiveWidget from './ArchiveWidget.astro';
import Badge88x31 from './Badge88x31.astro';
import Shoutbox from './Shoutbox.astro';
import FolderIcon from './icons/FolderIcon.astro';
import GlobeIcon from './icons/GlobeIcon.astro';
import FloppyIcon from './icons/FloppyIcon.astro';
import JoystickIcon from './icons/JoystickIcon.astro';
import ComputerIcon from './icons/ComputerIcon.astro';
import NotepadIcon from './icons/NotepadIcon.astro';

const posts = await getCollection('blog');

const categoriesMap: Record<string, number> = {};
const tagsMap: Record<string, number> = {};

posts.forEach((post) => {
	const cat = post.data.category || 'General';
	categoriesMap[cat] = (categoriesMap[cat] || 0) + 1;

	const tags = post.data.tags || [];
	tags.forEach((tag) => {
		tagsMap[tag] = (tagsMap[tag] || 0) + 1;
	});
});

const categories = Object.entries(categoriesMap);
const tags = Object.entries(tagsMap);

const daysOfWeek = ['S', 'M', 'T', 'W', 'T', 'F', 'S'];

const now = new Date();
const currentYear = now.getFullYear();
const currentMonth = now.getMonth();
const currentDay = now.getDate();

const monthNames = [
	"JANUARY", "FEBRUARY", "MARCH", "APRIL", "MAY",
	"JUNE", "JULY", "AUGUST", "SEPTEMBER", "OCTOBER",
	"NOVEMBER", "DECEMBER"
];
const currentMonthName = `${monthNames[currentMonth]} ${currentYear}`;

const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

const calendarDays: (number | string)[][] = [];
let currentWeek: (number | string)[] = [];

for (let i = 0; i < firstDayIndex; i++) {
	currentWeek.push('');
}

for (let day = 1; day <= totalDays; day++) {
	currentWeek.push(day);
	if (currentWeek.length === 7) {
		calendarDays.push(currentWeek);
		currentWeek = [];
	}
}

if (currentWeek.length > 0) {
	while (currentWeek.length < 7) {
		currentWeek.push('');
	}
	calendarDays.push(currentWeek);
}
---

<aside class="retro-sidebar">
	<Window title="webmaster.exe" theme="windows" icon="computer">
		<MoodWidget />
	</Window>

	<Window title="shoutbox.txt" theme="windows" icon="notepad">
		<Shoutbox />
	</Window>

	<Window title="winamp_2.82" theme="windows" icon="cd">
		<MusicPlayer />
	</Window>

	<Window title="calendar.sys" theme="windows" icon="notepad">
		<div class="calendar-widget">
			<div class="calendar-header" id="calendar-title">{currentMonthName}</div>
			<table class="calendar-table">
				<thead>
					<tr>
						{daysOfWeek.map((day) => <th>{day}</th>)}
					</tr>
				</thead>
				<tbody id="calendar-body">
					{calendarDays.map((week) => (
						<tr>
							{week.map((day) => (
								<td class={day === currentDay ? 'today' : ''}>
									{day}
								</td>
							))}
						</tr>
					))}
				</tbody>
			</table>
		</div>
	</Window>

	<Window title="blog_archives" theme="blue" icon="folder">
		<ArchiveWidget />
	</Window>

	<Window title="categories" theme="green" icon="folder">
		<div class="categories-widget">
			<ul class="cat-list">
				{categories.map(([cat, count]) => (
					<li>
						<FolderIcon size={12} class="cat-icon" />
						<a href={`${import.meta.env.BASE_URL}blog?category=${cat}`}>{cat}</a>
						<span class="cat-count">({count})</span>
					</li>
				))}
			</ul>
		</div>
	</Window>

	<Window title="tag_cloud" theme="yellow" icon="globe">
		<div class="tags-widget">
			{tags.map(([tag, count]) => {
				const size = 9 + Math.min(count * 2, 8);
				return (
					<a href={`${import.meta.env.BASE_URL}blog?tag=${tag}`} style={`font-size: ${size}px;`} class="tag-link">
						#{tag}
					</a>
				);
			})}
		</div>
	</Window>

	<Window title="favorite_links" theme="purple" icon="globe">
		<div class="links-widget">
			<ul class="links-list">
				<li><a href="https://astro.build" target="_blank" rel="noopener noreferrer"><GlobeIcon size={12} class="link-icon" /> Astro Home</a></li>
				<li><a href="https://w3schools.com" target="_blank" rel="noopener noreferrer"><NotepadIcon size={12} class="link-icon" /> W3Schools CSS</a></li>
				<li><a href="https://geocities.restorativland.org" target="_blank" rel="noopener noreferrer"><FloppyIcon size={12} class="link-icon" /> GeoCities Mirror</a></li>
				<li><a href="https://slashdot.org" target="_blank" rel="noopener noreferrer"><ComputerIcon size={12} class="link-icon" /> Slashdot News</a></li>
				<li><a href="https://www.animenewsnetwork.com" target="_blank" rel="noopener noreferrer"><JoystickIcon size={12} class="link-icon" /> Anime News</a></li>
			</ul>
		</div>
	</Window>

	<Window title="cool_buttons" theme="pink" icon="joystick">
		<div class="badges-widget">
			<div class="badge-row">
				<Badge88x31 type="ie6" />
				<Badge88x31 type="netscape" />
			</div>
			<div class="badge-row">
				<Badge88x31 type="notepad" />
				<Badge88x31 type="astro" />
			</div>
			<div class="badge-row">
				<Badge88x31 type="css" />
				<Badge88x31 type="webring" />
			</div>
		</div>
	</Window>
</aside>

<script>
	function buildCalendar() {
		const headerEl = document.getElementById('calendar-title');
		const bodyEl = document.getElementById('calendar-body');
		if (!headerEl || !bodyEl) return;

		const now = new Date();
		const currentYear = now.getFullYear();
		const currentMonth = now.getMonth(); // 0-indexed
		const currentDate = now.getDate(); // 1-indexed

		const monthNames = [
			"JANUARY", "FEBRUARY", "MARCH", "APRIL", "MAY",
			"JUNE", "JULY", "AUGUST", "SEPTEMBER", "OCTOBER",
			"NOVEMBER", "DECEMBER"
		];

		headerEl.textContent = `${monthNames[currentMonth]} ${currentYear}`;

		const firstDayIndex = new Date(currentYear, currentMonth, 1).getDay();
		const totalDays = new Date(currentYear, currentMonth + 1, 0).getDate();

		let html = '';
		let dayCount = 1;

		for (let i = 0; i < 6; i++) {
			let rowHtml = '<tr>';
			let addedAnyDay = false;

			for (let j = 0; j < 7; j++) {
				const cellIndex = i * 7 + j;
				if (cellIndex < firstDayIndex || dayCount > totalDays) {
					rowHtml += '<td></td>';
				} else {
					const isToday = dayCount === currentDate;
					rowHtml += `<td class="${isToday ? 'today' : ''}">${dayCount}</td>`;
					dayCount++;
					addedAnyDay = true;
				}
			}
			rowHtml += '</tr>';

			if (addedAnyDay || dayCount <= totalDays) {
				html += rowHtml;
			}
			if (dayCount > totalDays) {
				break;
			}
		}

		bodyEl.innerHTML = html;
	}

	buildCalendar();
</script>

<style lang="scss">
	@use "../styles/variables" as *;

	.retro-sidebar {
		width: 250px;
		display: flex;
		flex-direction: column;
		flex-shrink: 0;
	}

	.calendar-widget {
		background: #ffffff;
		@include win95-border-inset;
		padding: 5px;
	}

	.calendar-header {
		background: $win-blue;
		color: $win-white;
		text-align: center;
		font-family: $font-tahoma;
		font-size: 10px;
		font-weight: bold;
		padding: 2px 0;
		margin-bottom: 4px;
	}

	.calendar-table {
		width: 100%;
		border-collapse: collapse;
		text-align: center;
		font-family: $font-verdana;
		font-size: 10px;

		th {
			font-weight: bold;
			color: $win-dark-gray;
			padding: 2px 0;
			border-bottom: 1px solid $win-gray;
		}

		td {
			padding: 3px 0;
			width: 14.28%;
			transition: all 0.05s steps(2);

			&:not(:empty) {
				&:hover {
					background: $pastel-blue;
					color: $win-blue;
					outline: 1px dashed $win-blue;
					cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><path d='M10 2l3 0 0 12 3 0 0-7 2 0 0 7 1 0 0-6 2 0 0 6 1 0 0-5 2 0 0 9-1 0 0 2-1 0 0 1-1 0 0 1-7 0 0-1-3 0 0-1-1 0 0-5-2 0 0-3 2 0 0-3z' fill='white' stroke='black' stroke-width='1.5' stroke-linejoin='round'/></svg>") 10 2, pointer;
				}
			}

			&.today {
				background: $neon-yellow;
				color: #ff0000;
				font-weight: bold;
				outline: 1px dashed #ff0000;
				animation: blink-today 1.5s step-start infinite;

				&:hover {
					background: #ffff00;
					color: #ff0000;
					outline: 1px solid #ff0000;
				}
			}
		}
	}

	@keyframes blink-today {
		50% {
			background: $win-blue;
			color: $win-white;
			outline-color: $win-white;
		}
	}

	.categories-widget {
		background: #ffffff;
		@include win95-border-inset;
		padding: 6px;
	}

	.cat-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		font-family: $font-verdana;
		font-size: 11px;

		li {
			display: flex;
			align-items: center;
			gap: 6px;
			padding: 3px 6px;
			transition: all 0.05s ease;
			border-radius: 1px;

			a {
				color: #0000ee;
				text-decoration: none;
				flex-grow: 1;
			}

			&:hover {
				background: #000080;
				color: #ffffff;
				
				a {
					color: #ffffff;
					text-decoration: none;
				}
				
				.cat-count {
					color: #a0c0ff;
				}
				
				.cat-icon {
					filter: brightness(0) invert(1);
				}
			}
		}
	}

	.cat-bullet {
		font-size: 11px;
	}

	.cat-count {
		color: $win-dark-gray;
		font-weight: bold;
	}

	.tags-widget {
		background: #ffffff;
		@include win95-border-inset;
		padding: 10px;
		display: flex;
		flex-wrap: wrap;
		gap: 8px;
		justify-content: center;
		align-items: center;
	}

	.tag-link {
		color: $win-text;
		text-decoration: none;
		font-family: $font-retro-mono;
		padding: 2px 6px;
		background: #ffffff;
		border: 1px solid $win-dark-gray;
		box-shadow: 2px 2px 0px rgba(0, 0, 0, 0.2);
		display: inline-block;
		transition: all 0.1s ease-in-out;

		&:nth-child(5n+1) { border-color: #ff69b4; color: #d81b60; &:hover { background: #ffe4e1; } }
		&:nth-child(5n+2) { border-color: #00bfff; color: #0288d1; &:hover { background: #e0f7fa; } }
		&:nth-child(5n+3) { border-color: #32cd32; color: #388e3c; &:hover { background: #e8f5e9; } }
		&:nth-child(5n+4) { border-color: #ba55d3; color: #7b1fa2; &:hover { background: #f3e5f5; } }
		&:nth-child(5n+5) { border-color: #ff8c00; color: #e65100; &:hover { background: #fff3e0; } }

		&:hover {
			text-decoration: none;
			transform: translate(-1px, -1px);
			box-shadow: 3px 3px 0px rgba(0, 0, 0, 0.3);
		}

		&:active {
			transform: translate(1px, 1px);
			box-shadow: 1px 1px 0px rgba(0, 0, 0, 0.1);
		}
	}

	.links-widget {
		background: #ffffff;
		@include win95-border-inset;
		padding: 6px;
	}

	.cat-icon, .link-icon {
		flex-shrink: 0;
		transition: filter 0.05s ease;
	}

	.links-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 2px;
		font-family: $font-verdana;
		font-size: 11px;

		li {
			padding: 3px 6px;
			transition: all 0.05s ease;
			border-radius: 1px;
			display: flex;
			align-items: center;

			a {
				color: #0000ee;
				text-decoration: none;
				display: flex;
				align-items: center;
				gap: 6px;
				width: 100%;
				transition: transform 0.1s steps(2);
			}

			&:hover {
				background: #000080;
				color: #ffffff;

				a {
					color: #ffffff;
					text-decoration: none;
					transform: translateX(3px);
				}

				.link-icon {
					filter: brightness(0) invert(1);
				}
			}
		}
	}

	.badges-widget {
		display: flex;
		flex-direction: column;
		gap: 8px;
		align-items: center;
		background: #ffffff;
		@include win95-border-inset;
		padding: 8px;

		img {
			image-rendering: pixelated;
			transition: transform 0.1s steps(2);

			&:hover {
				transform: scale(1.1) rotate(2deg);
				filter: drop-shadow(2px 2px 0px rgba(0, 0, 0, 0.4));
			}
		}
	}

	.badge-row {
		display: flex;
		gap: 8px;
	}
</style>
