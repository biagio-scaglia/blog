---
import { Github, Linkedin, Mail, ShieldCheck } from 'lucide-astro';
const currentYear = new Date().getFullYear();
---

<footer class="footer galaxy-card">
  <div class="footer-content">
    <div class="footer-brand">
      <h2 class="heading-galaxy text-gradient">Biagio S.</h2>
      <p>Biagio Scaglia: Esplorando i confini tra Codice, Design e Gaming Culture.</p>
    </div>
    
    <div class="footer-links">
      <a href="https://github.com/biagio-scaglia" target="_blank" rel="noopener noreferrer" class="footer-link">
        <Github size={16} class="footer-icon" /> GitHub
      </a>
      <a href="https://linkedin.com/in/biagio-scaglia" target="_blank" rel="noopener noreferrer" class="footer-link">
        <Linkedin size={16} class="footer-icon" /> LinkedIn
      </a>
      <a href="mailto:biagio.scaglia01@gmail.com" class="footer-link">
        <Mail size={16} class="footer-icon" /> Contattami
      </a>
      <a href="/privacy" class="footer-link">
        <ShieldCheck size={16} class="footer-icon" /> Privacy Policy
      </a>
    </div>
  </div>
  
  <div class="footer-bottom">
    <p>&copy; {currentYear} Biagio Scaglia. Tutti i diritti riservati.</p>
    <a href="#" class="back-to-top">
      Torna in orbita ↑
    </a>
  </div>
</footer>

<style>
  .footer {
    margin-top: 6rem;
    /* Reduced horizontal 2.5rem to 1.5rem for ultra-small mobile safe fitting */
    padding: 3rem 1.5rem 2rem;
    border-bottom-left-radius: 0;
    border-bottom-right-radius: 0;
    border-bottom: none;
    box-sizing: border-box;
    width: 100%;
  }
  
  .footer-content {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    margin-bottom: 3rem;
  }
  
  @media (min-width: 768px) {
    .footer-content {
      flex-direction: row;
      justify-content: space-between;
      align-items: center;
    }
  }
  
  .footer-brand h2 {
    font-size: 2rem;
    margin-bottom: 0.5rem;
  }
  
  .footer-brand p {
    color: var(--text-secondary);
    font-size: 0.95rem;
    font-weight: 300;
  }
  
  .footer-links {
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  
  .footer-link {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color 0.3s ease;
  }
  
  .footer-icon {
    opacity: 0.7;
    transition: transform 0.3s ease, color 0.3s ease;
  }
  
  .footer-link:hover {
    color: var(--nebula-cyan);
    text-shadow: 0 0 10px rgba(0, 240, 255, 0.5);
  }
  
  .footer-link:hover .footer-icon {
    transform: translateY(-2px);
    color: #fff;
    opacity: 1;
  }
  
  .footer-bottom {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--glass-border);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.4);
    text-align: center;
  }
  
  @media (min-width: 768px) {
    .footer-bottom {
      flex-direction: row;
      justify-content: space-between;
      text-align: left;
    }
  }
  
  .back-to-top {
    font-weight: 500;
    color: var(--text-secondary);
    transition: color 0.3s ease;
  }
  
  .back-to-top:hover {
    color: var(--starlight);
  }
</style>
