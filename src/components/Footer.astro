---
import HitCounter from './HitCounter.astro';
import Webring from './Webring.astro';
---

<footer class="retro-footer">
	<hr class="footer-separator" />
	
	<div class="footer-widgets">
		<div class="footer-widget-item">
			<Webring />
		</div>
		<div class="footer-widget-item">
			<HitCounter start={84102} />
		</div>
	</div>

	<div class="footer-text-links">
		<a href="/">Home</a> | 
		<a href="/blog">Blog</a> | 
		<a href="/about">About</a> | 
		<a href="/rss.xml" target="_blank">RSS</a>
	</div>

	<div class="footer-copyright">
		<p class="copyright-line">💻 Designed & Maintain'd by Biagio Scaglia | 2004 - 2026 💻</p>
		<p class="best-viewed-line">Best viewed with 1024x768 resolution on Netscape Navigator 6.0 or IE 5.5+</p>
		<p class="disclaimer-line">No cookies were harmed in the making of this personal database.</p>
	</div>
</footer>

<style lang="scss">
	@use "../styles/variables" as *;

	.retro-footer {
		background: $win-gray;
		@include win95-border-outset;
		padding: 15px;
		margin-top: 20px;
		text-align: center;
		font-family: $font-verdana;
	}

	.footer-separator {
		border: none;
		height: 2px;
		@include win95-border-inset;
		margin-bottom: 15px;
	}

	.footer-widgets {
		display: flex;
		justify-content: space-around;
		align-items: center;
		flex-wrap: wrap;
		gap: 15px;
		margin-bottom: 15px;
	}

	.footer-widget-item {
		flex-shrink: 0;
	}

	.footer-text-links {
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		margin-bottom: 12px;

		a {
			color: #0000ee;
			text-decoration: none;
			margin: 0 4px;

			&:hover {
				color: #ff0000;
				text-decoration: underline;
			}
		}
	}

	.footer-copyright {
		font-size: 10px;
		color: #333333;
		line-height: 1.5;

		p {
			margin: 2px 0;
		}
	}

	.copyright-line {
		font-weight: bold;
		color: $win-blue;
	}

	.best-viewed-line {
		font-style: italic;
	}

	.disclaimer-line {
		color: $win-dark-gray;
	}
</style>
