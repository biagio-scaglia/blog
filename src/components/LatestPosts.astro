---
import { getCollection } from 'astro:content';
import FormattedDate from './FormattedDate.astro';

const posts = await getCollection('blog');
const recentPosts = posts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 5);
---

<div class="latest-posts-list">
	{recentPosts.map((post) => {
		const isNew = (Date.now() - post.data.pubDate.getTime()) < 1000 * 60 * 60 * 24 * 30; // 30 days
		return (
			<div class="post-item">
				<div class="post-header-row">
					<span class="post-category">[{post.data.category}]</span>
					<span class="post-date"><FormattedDate date={post.data.pubDate} /></span>
					{isNew && <span class="new-tag">NEW!</span>}
				</div>
				<a href={`${import.meta.env.BASE_URL}blog/${post.id}/`} class="post-title-link">
					{post.data.title}
				</a>
				<p class="post-desc">{post.data.description}</p>
			</div>
		);
	})}
</div>

<style lang="scss">
	@use "../styles/variables" as *;

	.latest-posts-list {
		display: flex;
		flex-direction: column;
		gap: 12px;
	}

	.post-item {
		background: #ffffff;
		@include win95-border-inset;
		padding: 10px;
		display: flex;
		flex-direction: column;
		gap: 4px;
	}

	.post-header-row {
		display: flex;
		align-items: center;
		gap: 8px;
		font-family: $font-tahoma;
		font-size: 10px;
		font-weight: bold;
	}

	.post-category {
		color: $win-blue;
	}

	.post-date {
		color: $win-dark-gray;
	}

	.new-tag {
		background: $neon-yellow;
		color: #ff0000;
		border: 1px dashed #ff0000;
		padding: 0 4px;
		font-size: 9px;
		animation: flash-badge 1s infinite step-start;
	}

	.post-title-link {
		font-family: $font-tahoma;
		font-size: 13px;
		font-weight: bold;
		color: #0000ff;
		text-decoration: underline;

		&:hover {
			color: #ff0000;
			background: #ffffe0;
		}
	}

	.post-desc {
		font-family: $font-verdana;
		font-size: 11px;
		color: #333;
		margin: 0;
		line-height: 1.3;
	}

	@keyframes flash-badge {
		0%, 100% { opacity: 1; background: $neon-yellow; }
		50% { opacity: 0; }
	}
</style>
