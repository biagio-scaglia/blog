---
import { Image } from 'astro:assets';
import catPic from '../assets/retro_cat.png';
import desktopPic from '../assets/retro_desktop.png';
import placeholderPic from '../assets/blog-placeholder-about.jpg';
---

<div class="latest-images-grid">
	<div class="polaroid-frame">
		<div class="image-inner">
			<Image src={catPic} alt="Sleeping Cat" class="retro-gallery-img" width={250} height={250} />
		</div>
		<div class="image-caption">My Sleepy Cat</div>
	</div>
	<div class="polaroid-frame">
		<div class="image-inner">
			<Image src={desktopPic} alt="Retro Desktop" class="retro-gallery-img" width={250} height={250} />
		</div>
		<div class="image-caption">Desktop Setup</div>
	</div>
	<div class="polaroid-frame">
		<div class="image-inner">
			<Image src={placeholderPic} alt="Placeholder Pic" class="retro-gallery-img" width={250} height={250} />
		</div>
		<div class="image-caption">Retro Space</div>
	</div>
</div>

<style lang="scss">
	@use "../styles/variables" as *;

	.latest-images-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 12px;
	}

	.polaroid-frame {
		background: #ffffff;
		border: 1px solid #999999;
		@include retro-shadow;
		padding: 6px;
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 4px;
	}

	.image-inner {
		border: 1px solid #cccccc;
		width: 100%;
		aspect-ratio: 1;
		overflow: hidden;
		display: flex;
		align-items: center;
		justify-content: center;
		background: #000;
	}

	.retro-gallery-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		image-rendering: pixelated;
	}

	.image-caption {
		font-family: $font-retro-mono;
		font-size: 9px;
		font-weight: bold;
		color: #333333;
		text-align: center;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		width: 100%;
		padding-top: 2px;
	}
</style>
