---
import { Image } from 'astro:assets';
import avatarImg from '../assets/avatar.png';
import ComputerIcon from './icons/ComputerIcon.astro';
import MusicIcon from './icons/MusicIcon.astro';
import JoystickIcon from './icons/JoystickIcon.astro';
import TVIcon from './icons/TVIcon.astro';
---

<div class="mood-widget">
	<div class="avatar-wrapper">
		<Image src={avatarImg} alt="Webmaster Avatar" class="retro-avatar-img" width={120} height={120} />
	</div>
	<div class="status-grid">
		<div class="status-item">
			<span class="status-label">Mood:</span>
			<span class="status-val">
				<ComputerIcon size={12} class="status-icon" />
				<span>Coding (React / .NET)</span>
			</span>
		</div>
		<div class="status-item">
			<span class="status-label">Listening:</span>
			<span class="status-val">
				<MusicIcon size={12} class="status-icon" />
				<span>Daft Punk - One More Time</span>
			</span>
		</div>
		<div class="status-item">
			<span class="status-label">Playing:</span>
			<span class="status-val">
				<JoystickIcon size={12} class="status-icon" />
				<span>Diablo II: Lord of Destruction</span>
			</span>
		</div>
		<div class="status-item">
			<span class="status-label">Watching:</span>
			<span class="status-val">
				<TVIcon size={12} class="status-icon" />
				<span>Serial Experiments Lain</span>
			</span>
		</div>
	</div>
</div>

<style lang="scss">
	@use "../styles/variables" as *;

	.mood-widget {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
	}

	.avatar-wrapper {
		@include win95-border-inset;
		background: #000;
		padding: 4px;
		width: 120px;
		height: 120px;
		display: flex;
		align-items: center;
		justify-content: center;
		transition: all 0.15s ease-in-out;

		&:hover {
			transform: scale(1.05) rotate(-1.5deg);
			outline: 2px solid $neon-magenta;
			box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.2);
		}
	}

	.retro-avatar-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		image-rendering: pixelated;
	}

	.status-grid {
		width: 100%;
		display: flex;
		flex-direction: column;
		gap: 6px;
		background: #ffffff;
		@include win95-border-inset;
		padding: 8px;
		font-family: $font-verdana;
		font-size: 11px;
	}

	.status-item {
		display: flex;
		flex-direction: column;
		border-bottom: 1px dashed #ccc;
		padding: 4px 2px;
		transition: all 0.1s steps(2);

		&:hover {
			background: #fffff2;
			outline: 1px dashed $win-blue;

			.status-icon {
				animation: wobble-status-icon 0.6s ease;
			}
		}

		&:last-child {
			border-bottom: none;
			padding-bottom: 0;
		}
	}

	.status-label {
		font-weight: bold;
		color: $win-blue;
		text-transform: uppercase;
		font-size: 9px;
		margin-bottom: 2px;
	}

	.status-val {
		color: #333;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.status-icon {
		flex-shrink: 0;
	}

	@keyframes wobble-status-icon {
		0%, 100% { transform: rotate(0deg) scale(1); }
		25% { transform: rotate(-12deg) scale(1.2); }
		75% { transform: rotate(12deg) scale(1.2); }
	}
</style>
