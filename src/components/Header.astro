---
import { Github, Linkedin, Home, User, PenTool, Code2 } from 'lucide-astro';
---

<!-- TOP HEADER (Always shows Logo, shows full Nav on Desktop) -->
<header class="header galaxy-card">
  <div class="header-container">
    <a href="/" class="logo">
      <span class="heading-galaxy text-gradient">Biagio S.</span>
    </a>
    
    <!-- Desktop Navigation -->
    <nav class="nav-menu desktop-nav">
      <ul class="nav-list">
        <li>
          <a href="/" class="nav-item">
            <Home size={16} class="nav-link-icon" /> Home
          </a>
        </li>
        <li>
          <a href="/about" class="nav-item">
            <User size={16} class="nav-link-icon" /> Chi Sono
          </a>
        </li>
        <li>
          <a href="/blog" class="nav-item">
            <PenTool size={16} class="nav-link-icon" /> Blog
          </a>
        </li>
      </ul>
    </nav>

    <!-- Desktop Socials -->
    <div class="social-links desktop-only">
      <a href="https://github.com/biagio-scaglia" target="_blank" rel="noopener noreferrer" class="nav-icon" aria-label="GitHub">
        <Github size={18} />
      </a>
      <a href="https://linkedin.com/in/biagio-scaglia" target="_blank" rel="noopener noreferrer" class="nav-icon" aria-label="LinkedIn">
        <Linkedin size={18} />
      </a>
    </div>
  </div>
</header>

<!-- BOTTOM NAVIGATION BAR (Mobile Only) -->
<nav class="mobile-bottom-nav">
  <div class="bottom-nav-container">
    <a href="/" class="bottom-nav-item">
      <Home size={22} class="bottom-icon" />
      <span class="bottom-label">Home</span>
    </a>
    <a href="/about" class="bottom-nav-item">
      <User size={22} class="bottom-icon" />
      <span class="bottom-label">Chi Sono</span>
    </a>
    <a href="/blog" class="bottom-nav-item">
      <PenTool size={22} class="bottom-icon" />
      <span class="bottom-label">Blog</span>
    </a>
  </div>
</nav>

<style>
  /* =========================================
     GLOBAL HEADER STYLES
     ========================================= */
  .header {
    margin-bottom: 3rem;
    padding: 0.75rem 1.5rem;
    position: sticky;
    top: 1rem;
    z-index: 1000;
    border-radius: 100px;
    background: rgba(11, 7, 26, 0.7);
    width: 100%;
    display: block; 
  }
  
  .header-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    margin: 0 auto;
    max-width: 1000px;
  }
  
  .logo {
    font-size: 1.25rem;
    text-decoration: none;
    line-height: 1;
    z-index: 1001;
  }
  
  /* =========================================
     MOBILE STYLES (Default / max-width: 767px)
     ========================================= */
  @media (max-width: 767px) {
    /* Hide Desktop Elements */
    .desktop-nav,
    .desktop-only {
      display: none !important;
    }
    
    /* Make the logo explicitly center on top for Mobile since it's the only thing there */
    .header-container {
      justify-content: center;
    }

    /* Bottom Navigation Bar */
    .mobile-bottom-nav {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      height: 70px;
      /* Heavy Glassmorphism for the dock */
      background: rgba(5, 2, 10, 0.85); 
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-top: 1px solid rgba(255, 255, 255, 0.08);
      z-index: 2000;
      display: flex;
      align-items: center;
      padding-bottom: env(safe-area-inset-bottom); /* iOS support */
      box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.5);
    }

    .bottom-nav-container {
      display: flex;
      justify-content: space-around;
      align-items: center;
      width: 100%;
      height: 100%;
      padding: 0 1rem;
    }

    .bottom-nav-item {
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 0.3rem;
      text-decoration: none;
      color: var(--text-secondary);
      flex: 1;
      height: 100%;
      transition: all 0.2s ease;
    }

    .bottom-icon {
      transition: transform 0.2s cubic-bezier(0.2, 0.8, 0.2, 1);
    }

    .bottom-label {
      font-size: 0.65rem;
      font-weight: 500;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    /* Active / Hover State */
    .bottom-nav-item:hover,
    .bottom-nav-item:active {
      color: var(--nebula-cyan);
    }

    .bottom-nav-item:hover .bottom-icon {
      transform: translateY(-3px) scale(1.1);
      filter: drop-shadow(0 0 8px rgba(0, 240, 255, 0.6));
    }
  }

  /* =========================================
     DESKTOP STYLES (min-width: 768px)
     ========================================= */
  @media (min-width: 768px) {
    .header {
      padding: 0.75rem 2rem;
      top: 1.5rem;
      margin-bottom: 4rem;
    }
    
    /* Hide the Mobile Bottom Navigation */
    .mobile-bottom-nav {
      display: none !important;
    }
    
    .logo {
      font-size: 1.5rem;
    }
    
    .desktop-nav {
      display: flex;
      flex-grow: 1;
      justify-content: center;
    }
    
    .nav-list {
      display: flex;
      flex-direction: row;
      list-style: none;
      gap: 1.5rem;
      margin: 0;
      padding: 0;
      align-items: center;
    }
    
    .nav-item {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-weight: 500;
      padding: 0.5rem 1.25rem;
      border-radius: 100px;
      font-size: 1rem;
      color: var(--text-secondary);
      white-space: nowrap;
      transition: all 0.3s ease;
    }
    
    .nav-link-icon {
      opacity: 0.7;
      transition: color 0.3s ease;
    }
    
    .nav-item:hover {
      color: var(--text-primary);
      background: var(--nebula-purple);
      box-shadow: 0 0 10px rgba(94, 23, 235, 0.5);
    }
    
    .nav-item:hover .nav-link-icon {
      color: var(--nebula-cyan);
      opacity: 1;
    }

    .desktop-only {
      display: flex;
    }
    
    .social-links {
      display: flex;
      flex-direction: row;
      gap: 0.75rem;
    }
    
    .nav-icon {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 38px;
      height: 38px;
      border-radius: 50%;
      color: var(--text-secondary);
      background: transparent;
      border: 1px solid transparent;
      transition: all 0.3s ease;
    }
    
    .nav-icon:hover {
      color: #fff;
      border-color: var(--nebula-cyan);
      background: var(--nebula-cyan);
      box-shadow: 0 0 15px rgba(0, 240, 255, 0.4);
    }
  }
</style>
