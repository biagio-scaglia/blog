---
import { SITE_TITLE } from '../consts';
---

<header class="retro-header">
	<div class="header-logo-container">
		<div class="logo-box">
			<h1 class="pixel-logo">{SITE_TITLE}</h1>
			<p class="slogan">~ Welcome to my personal database ~</p>
		</div>
	</div>
	
	<div class="code-banner">
		<!-- Starry background layer -->
		<div class="stars-layer" aria-hidden="true">
			<div class="star s-1" style="top: 15%; left: 10%;"></div>
			<div class="star s-2" style="top: 25%; left: 30%;"></div>
			<div class="star s-3" style="top: 10%; left: 75%;"></div>
			<div class="star s-1" style="top: 40%; left: 85%;"></div>
			<div class="star s-2" style="top: 75%; left: 15%;"></div>
			<div class="star s-3" style="top: 80%; left: 45%;"></div>
			<div class="star s-1" style="top: 70%; left: 70%;"></div>
			<div class="star s-2" style="top: 50%; left: 95%;"></div>
		</div>

		<!-- Pixel Art decorative SVG elements -->
		<div class="banner-decorations" aria-hidden="true">
			<!-- Rocket ship (top-left) -->
			<svg class="decor-item rocket" width="48" height="48" viewBox="0 0 16 16" style="image-rendering: pixelated; shape-rendering: crispEdges;">
				<path d="M0 6h2v4H0zm2 1h2v2H2z" fill="#ff0000" />
				<path d="M1 7h2v2H1z" fill="#ffaa00" />
				<rect x="2" y="8" width="1" height="1" fill="#ffff00" />
				<path d="M4 5h7v6H4z" fill="#ffffff" stroke="#000000" stroke-width="1" />
				<path d="M11 5h1v6h-1zm1 1h1v4h-1zm1 1h1v2h-1z" fill="#ff0000" stroke="#000000" stroke-width="1" />
				<path d="M3 4h2v1H3zm0 7h2v1H3z" fill="#0000ff" stroke="#000000" stroke-width="1" />
				<rect x="7" y="7" width="2" height="2" fill="#00ffff" stroke="#000000" stroke-width="1" />
			</svg>

			<!-- Alien head (bottom-left) -->
			<svg class="decor-item alien" width="44" height="44" viewBox="0 0 16 16" style="image-rendering: pixelated; shape-rendering: crispEdges;">
				<path d="M5 0h6v1h2v1h1v1h1v4h-1v2h-1v2h-1v2h-1v2H5v-2H4v-2H3v-2H2V7h1V3h1V2h1V1h1V0z" fill="#000000" />
				<path d="M5 1h6v1h1v1h1v4h-1v2h-1v2H9v2H7v-2H5v-2H4V7H3V3h1V2h1V1z" fill="#00ff66" />
				<path d="M4 5h3v3H4zm5 0h3v3H9z" fill="#000000" />
				<rect x="5" y="5" width="1" height="1" fill="#ffffff" />
				<rect x="10" y="5" width="1" height="1" fill="#ffffff" />
			</svg>

			<!-- Ringed Planet (top-right) -->
			<svg class="decor-item planet" width="70" height="70" viewBox="0 0 32 32" style="image-rendering: pixelated; shape-rendering: crispEdges;">
				<path d="M 2 20 L 7 17 L 11 17 L 6 20 Z" fill="#00ff66" />
				<path d="M 22 14 L 26 12 L 30 10 L 27 12 Z" fill="#00ff66" />
				<circle cx="16" cy="16" r="7" fill="#7b1fa2" stroke="#000000" stroke-width="1" />
				<path d="M 12 12 A 7 7 0 0 0 20 20 Z" fill="#4a148c" opacity="0.4" />
				<path d="M 4 21 L 28 11" stroke="#00ff66" stroke-width="2" stroke-linecap="round" />
				<circle cx="13" cy="13" r="1.5" fill="#ba68c8" />
			</svg>

			<!-- Shooting spaceship (bottom-right) -->
			<svg class="decor-item shooter" width="48" height="48" viewBox="0 0 16 16" style="image-rendering: pixelated; shape-rendering: crispEdges;">
				<path d="M13 11h2v3h-2zm-11 0h2v3H2z" fill="#0000ff" stroke="#000000" stroke-width="1" />
				<path d="M4 8h8v5H4z" fill="#ffffff" stroke="#000000" stroke-width="1" />
				<path d="M7 5h2v3H7z" fill="#ff0000" stroke="#000000" stroke-width="1" />
				<line x1="1" y1="2" x2="4" y2="5" stroke="#ffff00" stroke-width="1" />
			</svg>
		</div>

		<!-- Banner Text -->
		<div class="banner-text-box">
			<span class="banner-welcome">WELCOME TO...</span>
			<span class="banner-title" role="presentation">BIAGIO CYBERSPACE</span>
			<span class="banner-subtitle">EXPLORE THE VIRTUAL FRONTIER | SITE SINCE 2004</span>
		</div>
	</div>

	<marquee class="welcome-marquee" scrollamount="4" aria-label="Site announcement">
		★★★ Welcome to the galactic web logs of Biagio Cyberspace! Last updated: July 2026. Optimized for Netscape Navigator 4.0 and 800x600 resolution. ★★★
	</marquee>
	<nav class="header-menu" aria-label="Main navigation">
		<a href={import.meta.env.BASE_URL}>[ Home Page ]</a>
		<span class="divider" aria-hidden="true">|</span>
		<a href={`${import.meta.env.BASE_URL}blog`}>[ Blog Directory ]</a>
		<span class="divider" aria-hidden="true">|</span>
		<a href={`${import.meta.env.BASE_URL}interests`}>[ Interests ]</a>
		<span class="divider" aria-hidden="true">|</span>
		<a href={`${import.meta.env.BASE_URL}about`}>[ About Me ]</a>
		<span class="divider" aria-hidden="true">|</span>
		<a href={`${import.meta.env.BASE_URL}contributors`}>[ Contributors ]</a>
		<span class="divider" aria-hidden="true">|</span>
		<a href={`${import.meta.env.BASE_URL}rss.xml`} target="_blank" rel="noopener noreferrer">[ RSS Syndicate ]</a>
	</nav>
</header>

<style lang="scss">
	@use "../styles/variables" as *;

	.retro-header {
		background: $win-gray;
		@include win95-border-outset;
		padding: 6px;
		margin-bottom: 15px;
	}

	.header-logo-container {
		background: #000000;
		@include win95-border-inset;
		padding: 15px;
		text-align: center;
		margin-bottom: 6px;
		background-image: repeating-linear-gradient(45deg, #111, #111 2px, #000 2px, #000 4px);
	}

	.logo-box {
		display: inline-block;
	}

	.pixel-logo {
		font-family: $font-gothic;
		font-size: 32px;
		color: $neon-cyan;
		text-shadow: 2px 2px 0px $neon-magenta, -2px -2px 0px #000;
		margin: 0;
		text-transform: uppercase;
		letter-spacing: 2px;
		animation: pulse-shadow 2s infinite alternate;
	}

	.slogan {
		font-family: $font-retro-mono;
		font-size: 11px;
		color: $neon-green;
		margin: 5px 0 0 0;
	}

	.code-banner {
		@include win95-border-inset;
		background: #05051a;
		overflow: hidden;
		height: 150px;
		margin-bottom: 6px;
		display: flex;
		align-items: center;
		justify-content: center;
		position: relative;
		user-select: none;
	}

	.stars-layer {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.star {
		position: absolute;
		background: #ffffff;
		width: 2px;
		height: 2px;
		opacity: 0.8;
		
		&.s-1 {
			animation: twinkle 1s infinite alternate;
		}
		&.s-2 {
			animation: twinkle 1.5s infinite alternate;
		}
		&.s-3 {
			width: 3px;
			height: 3px;
			background: $neon-cyan;
			animation: twinkle 2s infinite alternate;
		}
	}

	.banner-decorations {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		pointer-events: none;
	}

	.decor-item {
		position: absolute;
		
		&.rocket {
			top: 15px;
			left: 5%;
			animation: drift-rocket 4s infinite alternate ease-in-out;
		}
		
		&.alien {
			bottom: 15px;
			left: 8%;
			animation: bob 3s infinite ease-in-out;
		}
		
		&.planet {
			top: 10px;
			right: 8%;
			animation: pulse-planet 6s infinite alternate ease-in-out;
		}
		
		&.shooter {
			bottom: 15px;
			right: 6%;
			animation: drift-shooter 5s infinite alternate ease-in-out;
		}
	}

	.banner-text-box {
		text-align: center;
		z-index: 10;
		font-family: 'VT323', monospace;
		display: flex;
		flex-direction: column;
		align-items: center;
		text-shadow: 2px 2px 0px #000;
	}

	.banner-welcome {
		color: $neon-yellow;
		font-size: 18px;
		letter-spacing: 2px;
		font-weight: bold;
		margin-bottom: 2px;
	}

	.banner-title {
		color: $neon-yellow;
		font-size: 48px;
		margin: 0;
		line-height: 1;
		font-weight: normal;
		text-shadow: 
			3px 3px 0px #000000, 
			-1px -1px 0px #000000, 
			1px -1px 0px #000000, 
			-1px 1px 0px #000000, 
			1px 1px 0px #000000;
		letter-spacing: 1px;
		animation: title-glow 3s infinite alternate;
	}

	.banner-subtitle {
		color: $neon-cyan;
		font-size: 16px;
		letter-spacing: 1px;
		margin-top: 4px;
		font-weight: bold;
	}

	.welcome-marquee {
		background: $win-blue;
		color: $neon-yellow;
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		padding: 2px 4px;
		@include win95-border-inset;
		margin-bottom: 6px;
	}

	nav.header-menu {
		@include win95-border-inset;
		background: $win-white;
		padding: 8px;
		text-align: center;
		font-family: $font-tahoma;
		font-size: 12px;
		font-weight: bold;

		a {
			color: #0000ee;
			text-decoration: none;
			padding: 2px 6px;

			&:hover {
				color: #ffffff;
				background: $win-blue;
			}
		}

		.divider {
			color: $win-dark-gray;
			margin: 0 4px;
		}
	}

	// Animations
	@keyframes twinkle {
		0% { opacity: 0.2; }
		100% { opacity: 1; }
	}

	@keyframes bob {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-5px); }
	}

	@keyframes drift-rocket {
		0% { transform: translate(0, 0) rotate(0deg); }
		100% { transform: translate(5px, -3px) rotate(2deg); }
	}

	@keyframes drift-shooter {
		0% { transform: translate(0, 0); }
		100% { transform: translate(-4px, 4px); }
	}

	@keyframes pulse-planet {
		0% { transform: scale(1) rotate(0deg); }
		100% { transform: scale(1.05) rotate(3deg); }
	}

	@keyframes title-glow {
		0% { color: $neon-yellow; }
		100% { color: #ffffff; text-shadow: 3px 3px 0px #000000, 0 0 8px rgba(255,255,0,0.5); }
	}

	@keyframes pulse-shadow {
		0% {
			text-shadow: 2px 2px 0px $neon-magenta;
		}
		100% {
			text-shadow: 2px 2px 0px $neon-yellow, -2px -2px 0px $neon-magenta;
		}
	}

	// Media queries for responsiveness (avoid squeezing)
	@media (max-width: 768px) {
		.decor-item {
			&.alien, &.rocket, &.shooter {
				display: none; // Hide smaller icons on small screens to avoid clutter
			}
			&.planet {
				right: 4%;
				width: 50px;
				height: 50px;
			}
		}
		
		.banner-title {
			font-size: 36px;
		}
		
		.banner-welcome {
			font-size: 14px;
		}
		
		.banner-subtitle {
			font-size: 12px;
		}
	}
</style>
