---
interface Props {
	size?: number;
	class?: string;
}
const { size = 16, class: className } = Astro.props;
---
<svg 
	xmlns="http://www.w3.org/2000/svg" 
	viewBox="0 0 16 16" 
	width={size} 
	height={size} 
	class={className}
	style="image-rendering: pixelated; shape-rendering: crispEdges; display: inline-block; vertical-align: middle;"
>
	<!-- Monitor Outer shell -->
	<rect x="1" y="1" width="14" height="10" fill="#c0c0c0" stroke="#000000" stroke-width="1" />
	<!-- Monitor Screen background -->
	<rect x="3" y="3" width="10" height="6" fill="#000000" />
	<!-- Screen Content (Cyan/Blue grid/logo) -->
	<rect x="4" y="4" width="8" height="4" fill="#008080" />
	<rect x="5" y="5" width="2" height="2" fill="#00ffff" />
	<!-- Monitor highlight border -->
	<line x1="2" y1="2" x2="13" y2="2" stroke="#ffffff" />
	<line x1="2" y1="2" x2="2" y2="9" stroke="#ffffff" />
	<!-- Stand -->
	<rect x="6" y="11" width="4" height="2" fill="#c0c0c0" stroke="#000000" stroke-width="1" />
	<!-- Computer Base Unit (Horizontal Desktop case) -->
	<rect x="0" y="13" width="16" height="3" fill="#c0c0c0" stroke="#000000" stroke-width="1" />
	<line x1="1" y1="14" x2="14" y2="14" stroke="#ffffff" />
	<!-- Floppy Drive Slot -->
	<line x1="3" y1="14" x2="8" y2="14" stroke="#808080" />
	<line x1="3" y1="15" x2="8" y2="15" stroke="#000000" />
	<!-- Power button -->
	<rect x="12" y="14" width="1" height="1" fill="#00ff00" />
</svg>
