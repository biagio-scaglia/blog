---
---

<div class="winamp-player">
	<div class="player-top">
		<div class="player-readout">
			<div class="visualizer">
				<div class="vis-bar"></div>
				<div class="vis-bar"></div>
				<div class="vis-bar"></div>
				<div class="vis-bar"></div>
				<div class="vis-bar"></div>
				<div class="vis-bar"></div>
			</div>
			<div class="digital-info">
				<div class="track-title">01. astronautical-apogee.mp3</div>
				<div class="track-time">00:00 / 02:00</div>
			</div>
		</div>
		<div class="kbps-info">128kbps 44kHz stereo</div>
	</div>
	<div class="player-controls">
		<div class="control-btn-winamp" id="wa-prev">PREV</div>
		<div class="control-btn-winamp" id="wa-play">PLAY</div>
		<div class="control-btn-winamp" id="wa-pause">PAUSE</div>
		<div class="control-btn-winamp" id="wa-stop">STOP</div>
		<div class="control-btn-winamp" id="wa-next">NEXT</div>
	</div>
	<div class="player-slider-row">
		<span class="slider-label">VOL:</span>
		<input type="range" class="winamp-vol" id="wa-vol" min="0" max="100" value="80" />
	</div>
</div>

<script>
	let audioCtx: AudioContext | null = null;
	let gainNode: GainNode | null = null;
	let isPlaying = false;
	let currentTrackIndex = 0;
	let volume = 0.8;
	let playbackTimer: number | null = null;
	let secondsElapsed = 0;

	const tracks = [
		{ title: "01. astronautical-apogee.mp3", duration: 120 },
		{ title: "02. geocities_sunrise.mp3", duration: 150 },
		{ title: "03. 56k_symphony.mp3", duration: 90 }
	];

	const playBtn = document.getElementById('wa-play');
	const pauseBtn = document.getElementById('wa-pause');
	const stopBtn = document.getElementById('wa-stop');
	const prevBtn = document.getElementById('wa-prev');
	const nextBtn = document.getElementById('wa-next');
	const volSlider = document.getElementById('wa-vol') as HTMLInputElement | null;
	
	const trackTitle = document.querySelector('.track-title');
	const trackTime = document.querySelector('.track-time');
	const visBars = document.querySelectorAll('.vis-bar');

	function initAudio() {
		if (audioCtx) return;
		try {
			const AudioContextClass = window.AudioContext || (window as any).webkitAudioContext;
			if (!AudioContextClass) return;
			audioCtx = new AudioContextClass();
			gainNode = audioCtx.createGain();
			gainNode.gain.setValueAtTime(volume, audioCtx.currentTime);
			gainNode.connect(audioCtx.destination);
		} catch (e) {
			console.warn("AudioContext failed to initialize.", e);
			audioCtx = null;
		}
	}

	// Simple Chiptune sound loops generator using Web Audio API
	let loopInterval: number | null = null;
	const melody = [261.63, 293.66, 329.63, 349.23, 392.00, 440.00, 493.88, 523.25]; // C major scale
	let noteIndex = 0;

	function startSynth() {
		if (!audioCtx || !gainNode) return;
		
		// Setup Synth loop
		loopInterval = window.setInterval(() => {
			if (!audioCtx || !gainNode) return;
			
			const osc = audioCtx.createOscillator();
			const noteGain = audioCtx.createGain();
			
			// Select waveform based on track
			osc.type = currentTrackIndex === 0 ? 'square' : currentTrackIndex === 1 ? 'sawtooth' : 'triangle';
			
			// Select frequency based on track melody
			let freq = melody[noteIndex % melody.length];
			if (currentTrackIndex === 1) freq = freq * 0.75; // lower pitch for track 2
			if (currentTrackIndex === 2) freq = freq * 1.25; // higher pitch for track 3
			
			osc.frequency.setValueAtTime(freq, audioCtx.currentTime);
			
			noteGain.gain.setValueAtTime(0.08, audioCtx.currentTime);
			noteGain.gain.exponentialRampToValueAtTime(0.0001, audioCtx.currentTime + 0.4);
			
			osc.connect(noteGain);
			noteGain.connect(gainNode);
			
			osc.start();
			osc.stop(audioCtx.currentTime + 0.5);
			
			noteIndex++;
		}, 250);
	}

	function stopSynth() {
		if (loopInterval) {
			clearInterval(loopInterval);
			loopInterval = null;
		}
	}

	function updateVisualizer(active: boolean) {
		visBars.forEach(bar => {
			(bar as HTMLElement).style.animationPlayState = active ? 'running' : 'paused';
		});
	}

	function formatTime(secs: number) {
		const m = Math.floor(secs / 60);
		const s = secs % 60;
		return `${String(m).padStart(2, '0')}:${String(s).padStart(2, '0')}`;
	}

	function updateTrackInfo() {
		if (trackTitle) trackTitle.textContent = tracks[currentTrackIndex].title;
		updateTimeDisplay();
	}

	function updateTimeDisplay() {
		if (trackTime) {
			const dur = tracks[currentTrackIndex].duration;
			trackTime.textContent = `${formatTime(secondsElapsed)} / ${formatTime(dur)}`;
		}
	}

	function startPlaybackTimer() {
		stopPlaybackTimer();
		playbackTimer = window.setInterval(() => {
			secondsElapsed++;
			if (secondsElapsed >= tracks[currentTrackIndex].duration) {
				nextTrack();
			} else {
				updateTimeDisplay();
			}
		}, 1000);
	}

	function stopPlaybackTimer() {
		if (playbackTimer) {
			clearInterval(playbackTimer);
			playbackTimer = null;
		}
	}

	function playTrack() {
		initAudio();
		if (audioCtx && audioCtx.state === 'suspended') {
			audioCtx.resume();
		}
		
		if (isPlaying) return;
		
		isPlaying = true;
		playBtn?.classList.add('playing');
		pauseBtn?.classList.remove('playing');
		
		startSynth();
		startPlaybackTimer();
		updateVisualizer(true);
	}

	function pauseTrack() {
		if (!isPlaying) return;
		isPlaying = false;
		playBtn?.classList.remove('playing');
		pauseBtn?.classList.add('playing');
		
		stopSynth();
		stopPlaybackTimer();
		updateVisualizer(false);
	}

	function stopTrack() {
		isPlaying = false;
		playBtn?.classList.remove('playing');
		pauseBtn?.classList.remove('playing');
		
		stopSynth();
		stopPlaybackTimer();
		secondsElapsed = 0;
		updateTimeDisplay();
		updateVisualizer(false);
	}

	function nextTrack() {
		currentTrackIndex = (currentTrackIndex + 1) % tracks.length;
		secondsElapsed = 0;
		updateTrackInfo();
		if (isPlaying) {
			stopSynth();
			startSynth();
		}
	}

	function prevTrack() {
		currentTrackIndex = (currentTrackIndex - 1 + tracks.length) % tracks.length;
		secondsElapsed = 0;
		updateTrackInfo();
		if (isPlaying) {
			stopSynth();
			startSynth();
		}
	}

	// Event Listeners
	playBtn?.addEventListener('click', playTrack);
	pauseBtn?.addEventListener('click', pauseTrack);
	stopBtn?.addEventListener('click', stopTrack);
	nextBtn?.addEventListener('click', nextTrack);
	prevBtn?.addEventListener('click', prevTrack);

	volSlider?.addEventListener('input', (e) => {
		const val = parseFloat((e.target as HTMLInputElement).value) / 100;
		volume = val;
		if (gainNode && audioCtx) {
			gainNode.gain.setValueAtTime(volume, audioCtx.currentTime);
		}
	});

	// Initialize time display
	updateTrackInfo();
	updateVisualizer(false);

	// Pause synth when tab is hidden to save CPU and prevent stuttering
	document.addEventListener('visibilitychange', () => {
		if (document.visibilityState === 'visible') {
			if (isPlaying) {
				startSynth();
				startPlaybackTimer();
				updateVisualizer(true);
				if (audioCtx && audioCtx.state === 'suspended') {
					audioCtx.resume();
				}
			}
		} else {
			if (isPlaying) {
				stopSynth();
				stopPlaybackTimer();
				updateVisualizer(false);
			}
		}
	});
</script>

<style lang="scss">
	@use "../styles/variables" as *;

	.winamp-player {
		background: #222222;
		border: 2px solid #555555;
		outline: 1px solid #111111;
		padding: 6px;
		display: flex;
		flex-direction: column;
		gap: 6px;
		font-family: $font-retro-mono;
		@include retro-shadow;
	}

	.player-top {
		background: #000000;
		border: 1px solid #444;
		padding: 4px;
		display: flex;
		flex-direction: column;
		gap: 2px;
	}

	.player-readout {
		display: flex;
		gap: 8px;
		align-items: center;
	}

	.visualizer {
		display: flex;
		align-items: flex-end;
		gap: 1px;
		width: 30px;
		height: 20px;
		background: #051a05;
		padding: 1px;
		border: 1px solid #1a3a1a;
	}

	.vis-bar {
		flex-grow: 1;
		background: #00ff00;
		border-radius: 1px 1px 0 0;
		height: 4px;
		animation-play-state: paused;

		&:nth-child(1) { animation: bounce 0.8s infinite alternate ease-in-out; }
		&:nth-child(2) { animation: bounce 1.1s infinite alternate ease-in-out; }
		&:nth-child(3) { animation: bounce 0.9s infinite alternate ease-in-out; }
		&:nth-child(4) { animation: bounce 1.3s infinite alternate ease-in-out; }
		&:nth-child(5) { animation: bounce 0.7s infinite alternate ease-in-out; }
		&:nth-child(6) { animation: bounce 1.0s infinite alternate ease-in-out; }
	}

	.digital-info {
		flex-grow: 1;
		overflow: hidden;
	}

	.track-title {
		color: $neon-green;
		font-size: 9px;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		animation: scroll-text 6s linear infinite;
	}

	.track-time {
		color: $neon-green;
		font-size: 10px;
		font-weight: bold;
	}

	.kbps-info {
		color: #008800;
		font-size: 8px;
		text-align: right;
		border-top: 1px solid #111;
		padding-top: 2px;
	}

	.player-controls {
		display: flex;
		justify-content: space-between;
		gap: 2px;
	}

	.control-btn-winamp {
		background: #333333;
		border: 1px solid #555555;
		color: #aaaaaa;
		font-size: 8px;
		font-weight: bold;
		padding: 4px 6px;
		text-align: center;
		cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><path d='M10 2l3 0 0 12 3 0 0-7 2 0 0 7 1 0 0-6 2 0 0 6 1 0 0-5 2 0 0 9-1 0 0 2-1 0 0 1-1 0 0 1-7 0 0-1-3 0 0-1-1 0 0-5-2 0 0-3 2 0 0-3z' fill='white' stroke='black' stroke-width='1.5' stroke-linejoin='round'/></svg>") 10 2, pointer;
		user-select: none;
		flex-grow: 1;

		&:hover {
			background: #444444;
			color: #ffffff;
		}

		&:active, &.playing {
			background: #111111;
			color: $neon-green;
			border-color: #222222;
		}
	}

	.player-slider-row {
		display: flex;
		align-items: center;
		gap: 4px;
	}

	.slider-label {
		color: #888888;
		font-size: 8px;
		font-weight: bold;
	}

	.winamp-vol {
		flex-grow: 1;
		height: 8px;
		background: #333;
		outline: none;
		-webkit-appearance: none;
		border: 1px solid #111;
		cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><path d='M10 2l3 0 0 12 3 0 0-7 2 0 0 7 1 0 0-6 2 0 0 6 1 0 0-5 2 0 0 9-1 0 0 2-1 0 0 1-1 0 0 1-7 0 0-1-3 0 0-1-1 0 0-5-2 0 0-3 2 0 0-3z' fill='white' stroke='black' stroke-width='1.5' stroke-linejoin='round'/></svg>") 10 2, pointer;

		&::-webkit-slider-runnable-track {
			background: #333;
		}

		&::-webkit-slider-thumb {
			-webkit-appearance: none;
			width: 10px;
			height: 10px;
			background: #888;
			border: 1px solid #fff;
			cursor: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32' viewBox='0 0 32 32'><path d='M10 2l3 0 0 12 3 0 0-7 2 0 0 7 1 0 0-6 2 0 0 6 1 0 0-5 2 0 0 9-1 0 0 2-1 0 0 1-1 0 0 1-7 0 0-1-3 0 0-1-1 0 0-5-2 0 0-3 2 0 0-3z' fill='white' stroke='black' stroke-width='1.5' stroke-linejoin='round'/></svg>") 10 2, pointer;
		}
	}

	@keyframes bounce {
		0% { height: 10%; }
		100% { height: 95%; }
	}

	@keyframes scroll-text {
		0%, 100% { transform: translateX(0); }
		50% { transform: translateX(10px); }
	}
</style>
