---
import '../styles/global.scss';
import type { ImageMetadata } from 'astro';
import FallbackImage from '../assets/blog-placeholder-1.jpg';
import { SITE_TITLE } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	image?: ImageMetadata;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const { title, description, image = FallbackImage } = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString() : 'https://biagioscaglia.dev';
const personId = `${siteUrl}#person`;
const websiteId = `${siteUrl}#website`;

const personSchema = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Person",
			"@id": personId,
			"name": "Biagio Scaglia",
			"jobTitle": "Full Stack Software Developer & UX/UI Designer",
			"url": siteUrl,
			"sameAs": [
				"https://github.com/biagioscaglia"
			],
			"knowsAbout": [
				"Software Development",
				"React",
				"TypeScript",
				".NET",
				"React Native",
				"UX/UI Design",
				"Retrocomputing",
				"Tabletop RPGs"
			],
			"description": "Biagio Scaglia is a Full Stack Software Developer, UX/UI Designer, and the creator of 'Vellum - RPG Companion' mobile app."
		},
		{
			"@type": "WebSite",
			"@id": websiteId,
			"url": siteUrl,
			"name": "Biagio Cyberspace",
			"description": "Biagio Scaglia's personal blog: full-stack developer, UX/UI designer, and lover of the retro web.",
			"publisher": {
				"@id": personId
			}
		}
	]
};
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<script type="application/ld+json" is:inline set:html={JSON.stringify(personSchema)} />
<link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
<link rel="icon" href={`${import.meta.env.BASE_URL}favicon.ico`} />
<link rel="sitemap" href={`${import.meta.env.BASE_URL}sitemap-index.xml`} />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL(`${import.meta.env.BASE_URL}rss.xml`, Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=VT323&display=swap" rel="stylesheet">

<Font cssVariable="--font-atkinson" preload />

<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="description" content={description} />

<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(image.src, Astro.url)} />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={Astro.url} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(image.src, Astro.url)} />

