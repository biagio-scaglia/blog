---
import { Home, ChevronRight } from 'lucide-astro';

export interface Props {
  paths: {
    name: string;
    url: string;
  }[];
}

const { paths } = Astro.props;
---

<nav class="breadcrumbs" aria-label="Breadcrumb">
  <ol class="breadcrumb-list">
    <li class="breadcrumb-item">
      <a href="/" class="breadcrumb-link home-link" aria-label="Home">
        <Home size={16} />
      </a>
    </li>
    
    {paths.map((path, index) => {
      const isLast = index === paths.length - 1;
      return (
        <li class="breadcrumb-item">
          <ChevronRight size={14} class="separator" />
          {isLast ? (
            <span class="breadcrumb-current" aria-current="page">{path.name}</span>
          ) : (
            <a href={path.url} class="breadcrumb-link">{path.name}</a>
          )}
        </li>
      );
    })}
  </ol>
</nav>

<style>
  .breadcrumbs {
    margin-bottom: 2rem;
    padding: 0.75rem 1.25rem;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    border-radius: 100px;
    backdrop-filter: blur(10px);
    display: inline-block;
  }
  
  .breadcrumb-list {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .breadcrumb-item {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9rem;
  }
  
  .breadcrumb-link {
    color: var(--text-secondary);
    text-decoration: none;
    transition: color 0.2s ease, text-shadow 0.2s ease;
    display: flex;
    align-items: center;
  }
  
  .breadcrumb-link:hover {
    color: var(--nebula-cyan);
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.4);
  }
  
  .home-link {
    color: var(--text-secondary);
  }
  
  .home-link:hover {
    color: var(--text-primary);
  }
  
  .separator {
    color: rgba(255, 255, 255, 0.2);
  }
  
  .breadcrumb-current {
    color: var(--text-primary);
    font-weight: 500;
  }
  
  @media (max-width: 600px) {
    .breadcrumbs {
      padding: 0.5rem 1rem;
      margin-bottom: 1.5rem;
    }
    .breadcrumb-item {
      font-size: 0.85rem;
    }
  }
</style>
