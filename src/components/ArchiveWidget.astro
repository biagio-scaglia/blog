---
import { getCollection } from 'astro:content';
import FolderIcon from './icons/FolderIcon.astro';

const posts = await getCollection('blog');
const sortedPosts = posts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const archiveMap: Record<string, { label: string; count: number; slug: string }> = {};

sortedPosts.forEach((post) => {
	const date = post.data.pubDate;
	const year = date.getFullYear();
	const month = String(date.getMonth() + 1).padStart(2, '0');
	const key = `${year}-${month}`;
	const label = date.toLocaleDateString('en-US', { month: 'long', year: 'numeric' });

	if (!archiveMap[key]) {
		archiveMap[key] = { label, count: 0, slug: key };
	}
	archiveMap[key].count++;
});

const archives = Object.values(archiveMap);
---

<div class="archive-widget">
	<ul class="archive-list">
		{archives.map((arch) => (
			<li>
				<FolderIcon size={12} class="archive-bullet" />
				<a href={`/blog?archive=${arch.slug}`}>{arch.label}</a>
				<span class="count-badge">({arch.count})</span>
			</li>
		))}
	</ul>
</div>

<style lang="scss">
	@use "../styles/variables" as *;

	.archive-widget {
		background: #ffffff;
		@include win95-border-inset;
		padding: 8px;
		font-family: $font-verdana;
		font-size: 11px;
	}

	.archive-list {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 6px;

		li {
			display: flex;
			align-items: center;
			gap: 6px;
		}
	}

	.archive-bullet {
		flex-shrink: 0;
	}

	a {
		color: #0000ee;
		text-decoration: none;

		&:hover {
			text-decoration: underline;
			color: #ff0000;
		}
	}

	.count-badge {
		color: $win-dark-gray;
		font-weight: bold;
	}
</style>
