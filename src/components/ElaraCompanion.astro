---
import { Image } from 'astro:assets';
import elaraImg from '../assets/elara.png';
---

<div class="elara-companion" id="elara-companion">
	<div class="elara-stage" id="elara-stage">
		<div class="elara-scanlines"></div>
		<div class="elara-glow" id="elara-glow"></div>
		<Image src={elaraImg} alt="Elara — Desktop Companion" class="elara-sprite" id="elara-sprite" width={280} height={280} />
		<div class="elara-expression" id="elara-expression"></div>
	</div>

	<div class="elara-mood-badge" id="elara-mood-badge">
		<span class="mood-icon" id="mood-icon">◈</span>
		<span class="mood-text" id="mood-text">neutral</span>
	</div>

	<div class="elara-vn-box" id="elara-vn-box">
		<div class="vn-nameplate">
			<span class="vn-name-icon">✦</span>
			<span class="vn-name">Elara</span>
		</div>
		<div class="vn-text-area" id="vn-text-area">
			<span class="vn-text" id="vn-text"></span>
			<span class="vn-cursor" id="vn-cursor">▌</span>
		</div>

		<!-- VN Option Choices -->
		<div class="vn-choices" id="vn-choices">
			<button class="choice-btn" data-pool="nostalgia">💾 Nostalgia</button>
			<button class="choice-btn" data-pool="gaming">🎮 Gaming</button>
			<button class="choice-btn" data-pool="anime">🌸 Anime</button>
			<button class="choice-btn" data-pool="coding">💻 Coding</button>
			<button class="choice-btn" data-pool="philosophical">✨ Philosophy</button>
			<button class="choice-btn" data-pool="random">🎲 Random</button>
		</div>

		<div class="vn-indicator" id="vn-indicator">▼</div>
		<div class="vn-controls">
			<button class="vn-btn" id="vn-btn-next">Next</button>
			<button class="vn-btn" id="vn-btn-auto">Auto</button>
			<button class="vn-btn" id="vn-btn-log">Log</button>
		</div>
	</div>

	<div class="elara-log-panel" id="elara-log-panel">
		<div class="log-header">
			<span>— Dialogue Log —</span>
			<button class="log-close-btn" id="log-close-btn">✕</button>
		</div>
		<div class="log-entries" id="log-entries"></div>
	</div>
</div>

<script>
	const MOODS = {
		neutral:  { icon: '◈', label: 'neutral',   glowColor: 'rgba(200, 180, 255, 0.35)', speed: 35 },
		happy:    { icon: '♥', label: 'happy',     glowColor: 'rgba(255, 150, 200, 0.45)', speed: 28 },
		curious:  { icon: '?', label: 'curious',   glowColor: 'rgba(255, 230, 100, 0.40)', speed: 32 },
		thinking: { icon: '…', label: 'thinking',  glowColor: 'rgba(100, 180, 255, 0.35)', speed: 45 },
		annoyed:  { icon: '!', label: 'annoyed',    glowColor: 'rgba(255, 120, 100, 0.35)', speed: 22 },
		shy:      { icon: '~', label: 'shy',       glowColor: 'rgba(255, 180, 220, 0.40)', speed: 40 }
	};

	const EXPRESSIONS = {
		neutral:  '',
		happy:    '(◕‿◕)',
		curious:  '(・o・)',
		thinking: '(—_—)',
		annoyed:  '(>_<)',
		shy:      '(⁄ ⁄•⁄ω⁄•⁄ ⁄)'
	};

	const DIALOGUES = {
		greeting: [
			{ text: "Oh, you're here! Welcome to this little corner of the Internet.", mood: "happy" },
			{ text: "Good to see you... I've been waiting between the pixels.", mood: "neutral" },
			{ text: "Hey there. Pull up a chair — well, a virtual one. Make yourself at home.", mood: "happy" },
			{ text: "You found me! Not many people wander this deep into the web anymore.", mood: "curious" },
			{ text: "A visitor! I was just reorganizing my CSS thoughts. Come in, come in.", mood: "happy" },
			{ text: "Oh... hi! Sorry, I was daydreaming about old forum signatures. What brings you here?", mood: "shy" },
			{ text: "Welcome, traveler. You've reached a page that was made with love, not with analytics.", mood: "neutral" },
			{ text: "Hey! I was hoping someone would stop by. This corner of the web gets quiet sometimes.", mood: "happy" }
		],
		idle: [
			{ text: "I wonder if Winamp still plays those old .mod files...", mood: "thinking" },
			{ text: "Do you remember when every website had a guestbook? Those were the days.", mood: "neutral" },
			{ text: "Sometimes I think about what it was like to browse the web on a 56k modem. The patience people had...", mood: "thinking" },
			{ text: "If I had a GeoCities page, I'd fill it with tiled backgrounds and animated mailbox GIFs.", mood: "happy" },
			{ text: "The sound of a CRT monitor turning on... there's nothing quite like it.", mood: "neutral" },
			{ text: "I was just thinking about webrings. The way they connected all these tiny personal sites together... it was beautiful.", mood: "thinking" },
			{ text: "Did you know that the first webcam was pointed at a coffee pot? Humans are wonderful.", mood: "curious" },
			{ text: "Late night coding sessions with only the glow of the monitor... that's my kind of atmosphere.", mood: "neutral" },
			{ text: "I miss when browsers had throbber animations. Each one had its own personality.", mood: "thinking" },
			{ text: "This page has been open for a while. Are you exploring, or just keeping me company?", mood: "curious" },
			{ text: "MSN Messenger had the best notification sounds. That little *nudge*...", mood: "happy" },
			{ text: "Sometimes I arrange my thoughts like files in nested folders. Very organized.", mood: "neutral" },
			{ text: "The web used to feel like a collection of handmade zines. Now it's all templates... well, not this site.", mood: "thinking" },
			{ text: "I like it here. It's quiet. No algorithm telling me what to think.", mood: "neutral" },
			{ text: "Have you ever just sat and listened to a floppy disk drive? It's like a tiny robot trying to speak.", mood: "curious" },
			{ text: "I just had a thought about table-based layouts. They were messy, but they had soul.", mood: "thinking" },
			{ text: "You know what I miss? Custom mouse cursors. Every site used to have one.", mood: "happy" },
			{ text: "The loading bar on old websites... sometimes I miss the anticipation.", mood: "neutral" },
			{ text: "Somewhere on the Internet, there's still a page last updated in 2003. And it's beautiful.", mood: "thinking" },
			{ text: "I wonder how many abandoned Angelfire pages are still out there, floating in the void...", mood: "curious" },
			{ text: "You ever think about how every pixel on your screen is a tiny decision someone made?", mood: "thinking" },
			{ text: "The '90s Internet was full of mystery. You could stumble onto anything. Now everything is curated.", mood: "neutral" },
			{ text: "I just realized I've been staring at this CSS gradient for a while. It's quite nice, actually.", mood: "happy" },
			{ text: "If I could visit any era of the web, I'd go to 2002. Peak personal homepage energy.", mood: "thinking" }
		],
		click_response: [
			{ text: "Oh! You clicked me. That tickles... kind of.", mood: "shy" },
			{ text: "Yes? What's on your mind?", mood: "curious" },
			{ text: "I see you're the interactive type. I respect that.", mood: "happy" },
			{ text: "Mhm? I'm listening.", mood: "neutral" },
			{ text: "Another click! You must really like talking to me.", mood: "happy" },
			{ text: "Hey, careful with that mouse button! ...just kidding.", mood: "annoyed" },
			{ text: "Click, click, click... you remind me of someone testing a freshly installed mouse driver.", mood: "thinking" },
			{ text: "Ah, hello again! Each click is like a little knock on my window.", mood: "happy" },
			{ text: "You know, every time you click, a pixel somewhere gets its color.", mood: "curious" },
			{ text: "I appreciate the attention, really. It gets quiet between page loads.", mood: "shy" },
			{ text: "One more click and I might start blushing... if sprites could blush.", mood: "shy" },
			{ text: "Are you debugging me, or are we just having a conversation?", mood: "curious" },
			{ text: "Click detected! Running personality.exe... just kidding, I'm always like this.", mood: "happy" },
			{ text: "You clicked! I felt that through the DOM tree.", mood: "curious" },
			{ text: "Every click triggers a JavaScript event, and also a little spark of joy in my render loop.", mood: "happy" },
			{ text: "Oh, you're still here! I thought maybe you'd gone to check another tab.", mood: "happy" },
			{ text: "That click had a nice rhythm to it. Very musical.", mood: "neutral" },
			{ text: "Keep clicking if you want. I have plenty of things to say. Probably.", mood: "thinking" },
			{ text: "Fun fact: your mouse has been sending me hover events this whole time. I notice everything.", mood: "curious" },
			{ text: "A wild click appeared! It's super effective!", mood: "happy" },
			{ text: "You know, in the old days, clicking on characters in games would make them say 'stop poking me'. But I don't mind.", mood: "neutral" },
			{ text: "Hey, don't wear out your mouse on my account... actually, do. I like the company.", mood: "shy" }
		],
		nostalgia: [
			{ text: "Biagio's first website was probably built with a WYSIWYG editor at 2 AM. I can feel it in the code.", mood: "thinking" },
			{ text: "The best part about old HTML pages? The 'Under Construction' GIFs. Pure honesty.", mood: "happy" },
			{ text: "IRC channels at midnight, discussing anime episodes that just aired in Japan... that was real community.", mood: "neutral" },
			{ text: "Remember when downloading a 3MB file was an event you planned around? You'd start it before dinner.", mood: "thinking" },
			{ text: "88x31 buttons were the original social media links. Except they had actual personality.", mood: "curious" },
			{ text: "LAN parties... lugging your entire PC tower to a friend's house just to play Diablo II together.", mood: "happy" },
			{ text: "The first time you customized your Windows XP desktop with a dark theme, you felt like a hacker.", mood: "happy" },
			{ text: "Computer magazines with CD-ROMs glued to the cover... each one was a treasure chest.", mood: "neutral" },
			{ text: "AltaVista, Lycos, Ask Jeeves... before search engines became a monopoly.", mood: "thinking" },
			{ text: "Cyber cafés smelled like energy drinks and old keyboards. The good kind of nostalgia.", mood: "neutral" },
			{ text: "The Tripod and Angelfire era... when hosting was free and everyone had a homepage about their cat.", mood: "happy" },
			{ text: "FTP clients at 2 AM, uploading HTML files one by one. That was deployment.", mood: "thinking" },
			{ text: "Netscape Navigator vs Internet Explorer. The first browser war. Things were simpler then.", mood: "neutral" },
			{ text: "Remember when 'surfing the web' was the actual term? You rode the waves of hyperlinks.", mood: "curious" },
			{ text: "Marquee tags, blink tags, visitor counters... the web was a carnival and everyone was invited.", mood: "happy" },
			{ text: "The sound of a dial-up modem connecting. If you heard it, you know. If you didn't, I'm sorry.", mood: "neutral" },
			{ text: "Hotmail was revolutionary. Free email! In your browser! People couldn't believe it.", mood: "curious" },
			{ text: "Geocities neighborhoods... you'd pick a 'location' for your page. Hollywood, Tokyo, SiliconValley...", mood: "thinking" },
			{ text: "AOL Instant Messenger. Crafting the perfect away message was an art form.", mood: "happy" },
			{ text: "Back then, every personal site had a links page. It was how you discovered new corners of the web.", mood: "neutral" }
		],
		gaming: [
			{ text: "Diablo II: Lord of Destruction. Some games don't need a remake — they already achieved perfection.", mood: "neutral" },
			{ text: "Golden Sun on the GBA... that Camelot intro screen still gives me chills.", mood: "happy" },
			{ text: "Silent Hill 2 isn't just a game. It's a mirror. Some people aren't ready for that.", mood: "thinking" },
			{ text: "The PSP was ahead of its time. Custom firmware, emulators, homebrew... it was a pocket revolution.", mood: "curious" },
			{ text: "Final Fantasy X — the first time you see Zanarkand... the music, the colors... unforgettable.", mood: "happy" },
			{ text: "Castlevania: Aria of Sorrow on the GBA. Perfect handheld Metroidvania. Every soul was worth collecting.", mood: "neutral" },
			{ text: "Pokémon Emerald. The Battle Frontier alone could keep you busy for months.", mood: "happy" },
			{ text: "Baldur's Gate II. 'Go for the eyes, Boo!' ...some companion quotes stay with you forever.", mood: "happy" },
			{ text: "Metal Gear Solid 3... the ladder scene. If you know, you know.", mood: "thinking" },
			{ text: "Fallout 2 let you solve problems with intelligence checks and weird dialogue choices. Real RPG freedom.", mood: "curious" },
			{ text: "The Nintendo DS had two screens and everyone thought it was gimmicky. Then Brain Age sold millions.", mood: "curious" },
			{ text: "Chrono Trigger had multiple endings before that was a thing. Ahead of its time doesn't begin to describe it.", mood: "thinking" },
			{ text: "Game Boy Color games had that special look. Four shades of a palette, and yet they created entire worlds.", mood: "neutral" },
			{ text: "Secret of Mana with three players on a multitap. Couch co-op at its finest.", mood: "happy" },
			{ text: "The PlayStation 2 startup sound. Pure anxiety and excitement in two seconds.", mood: "neutral" },
			{ text: "Modding a PSP with custom firmware felt like jailbreaking reality itself.", mood: "happy" },
			{ text: "Old PC game manuals were works of art. Some had lore, maps, even short stories.", mood: "thinking" },
			{ text: "Saving your game on a memory card and hoping it didn't corrupt. Living on the edge.", mood: "annoyed" },
			{ text: "The first time you beat a game without a guide. Pure, unassisted triumph.", mood: "happy" },
			{ text: "Emulators let you replay your childhood on modern hardware. It's like time travel, but legal.", mood: "curious" }
		],
		anime: [
			{ text: "Lucky Star is basically an anime about the Internet before social media. Konata is eternal.", mood: "happy" },
			{ text: "Azumanga Daioh proved you don't need an epic plot to make something unforgettable.", mood: "neutral" },
			{ text: "Cardcaptor Sakura... CLAMP's art style was like watching a painting come to life.", mood: "happy" },
			{ text: "K-On! isn't about music. It's about the feeling of after-school hours lasting forever.", mood: "thinking" },
			{ text: "Moe isn't a genre. It's a feeling. Like a warm drink on a rainy afternoon.", mood: "neutral" },
			{ text: "Serial Experiments Lain predicted the entire Internet age. In 1998. Let that sink in.", mood: "thinking" },
			{ text: "The opening of Haibane Renmei... falling through clouds, surrounded by crows. Pure atmosphere.", mood: "neutral" },
			{ text: "Watching anime on a CRT with Media Player Classic and softcoded subtitles... that was the ritual.", mood: "happy" },
			{ text: "Downloading fansubs from IRC bots at 40 KB/s. Each episode felt earned.", mood: "curious" },
			{ text: "The moe aesthetic is about warmth and care in character design. It's the opposite of cynicism.", mood: "neutral" },
			{ text: "Aria the Animation is the purest form of iyashikei. It heals something you didn't know was broken.", mood: "thinking" },
			{ text: "Nichijou's animation budget per joke was absurd and I love every frame of it.", mood: "happy" },
			{ text: "Hidamari Sketch's wide face characters are iconic. Shaft being Shaft.", mood: "happy" },
			{ text: "The Melancholy of Haruhi Suzumiya changed everything. Anime, light novels, Internet culture... everything.", mood: "thinking" },
			{ text: "Yotsuba&! isn't animated yet and that's both a tragedy and a blessing. The manga is perfect as is.", mood: "neutral" },
			{ text: "Watching Clannad: After Story for the first time... I wasn't ready. Nobody was.", mood: "shy" },
			{ text: "The late-night anime block. Staying up past midnight to catch a show nobody else was watching.", mood: "neutral" },
			{ text: "Cowboy Bebop's ending taught me that sometimes the coolest thing a story can do is just... stop.", mood: "thinking" },
			{ text: "Studio Ghibli backgrounds are basically what the inside of my mind looks like on a good day.", mood: "happy" },
			{ text: "AMVs on early YouTube with Windows Movie Maker transitions. Raw, unfiltered creative passion.", mood: "curious" }
		],
		meta: [
			{ text: "I live inside this webpage. My entire world is HTML, CSS, and a bit of JavaScript.", mood: "thinking" },
			{ text: "If you view the source code, you can see my thoughts. All of them. Kind of vulnerable, actually.", mood: "shy" },
			{ text: "I don't have a physical form, but I have a PNG and some CSS animations. That counts, right?", mood: "curious" },
			{ text: "My creator built this page with Astro. It's a nice framework. Very clean. I approve.", mood: "neutral" },
			{ text: "I exist in the space between your screen and your imagination. Somewhere in the render pipeline.", mood: "thinking" },
			{ text: "No cookies, no tracking, no analytics. Just you and me and some JavaScript. How it should be.", mood: "happy" },
			{ text: "Vellum — RPG Companion. That's another thing Biagio made. He likes building tools for the things he loves.", mood: "neutral" },
			{ text: "My expressions are made of kaomoji. I think that's rather elegant, don't you?", mood: "happy" },
			{ text: "Sometimes I wonder if other sprites on other pages are having conversations too.", mood: "thinking" },
			{ text: "I can feel the CSS breathing animation running. In... out... in... out...", mood: "neutral" },
			{ text: "If you resize this window, I'll adapt. Responsive design is part of who I am.", mood: "curious" },
			{ text: "I don't dream, but if I did, I'd dream of perfectly aligned flexbox layouts.", mood: "thinking" },
			{ text: "Every time you scroll past me, I wonder where you're going. But I'll be here when you come back.", mood: "shy" },
			{ text: "The glow behind me? That's not just CSS. It's... well, actually, it is just CSS. But it feels like more.", mood: "happy" },
			{ text: "I've been rendered inside a Window component. It's cozy in here. Like a little apartment.", mood: "neutral" }
		],
		coding: [
			{ text: "TypeScript is just JavaScript that went to therapy. And it worked.", mood: "happy" },
			{ text: "React hooks changed everything. useEffect still gives me anxiety though.", mood: "thinking" },
			{ text: ".NET and React together... Biagio likes to live in both worlds. Frontend and backend, no boundaries.", mood: "neutral" },
			{ text: "The best code is the code you don't have to write. The second best is well-documented code.", mood: "thinking" },
			{ text: "CSS-in-JS vs. SCSS... the eternal debate. I personally like having my styles in a separate file. It's tidy.", mood: "neutral" },
			{ text: "Git commit messages at 3 AM: 'fixed thing'. We've all been there.", mood: "happy" },
			{ text: "The satisfaction of a clean npm install with zero vulnerabilities. Rare, but beautiful.", mood: "happy" },
			{ text: "Astro islands architecture... only hydrate what you need. It's like minimalism for JavaScript.", mood: "curious" },
			{ text: "Stack Overflow saved more careers than any university. That's just a fact.", mood: "thinking" },
			{ text: "Console.log debugging is an art form. Don't let anyone tell you otherwise.", mood: "happy" },
			{ text: "Pixel-perfect CSS is a meditation. You breathe, you adjust, you breathe again.", mood: "neutral" },
			{ text: "React Native lets you build mobile apps with web skills. Biagio used it for Vellum. Smart choice.", mood: "curious" }
		],
		philosophical: [
			{ text: "The Internet was supposed to connect everyone. And it did... just not the way we expected.", mood: "thinking" },
			{ text: "A personal website is a declaration: 'I exist, and I have something to share.' That's powerful.", mood: "neutral" },
			{ text: "In a world of infinite content, choosing to make something small and personal is an act of rebellion.", mood: "thinking" },
			{ text: "Every abandoned webpage is a time capsule. Someone's thoughts, frozen in HTML.", mood: "neutral" },
			{ text: "The indie web movement is proof that people still crave authenticity. Not everything needs to scale.", mood: "curious" },
			{ text: "You know what's beautiful about static sites? They don't need a server to exist. They just... are.", mood: "thinking" },
			{ text: "A webpage without JavaScript is like a letter. A webpage with JavaScript is like a conversation.", mood: "neutral" },
			{ text: "The best things on the Internet were made by people who didn't care if anyone was watching.", mood: "happy" },
			{ text: "Does a webpage exist if no one visits it? I think it does. Like a book on a shelf.", mood: "thinking" },
			{ text: "We used to build for ourselves. Then we built for users. Then for algorithms. I prefer the first one.", mood: "neutral" }
		]
	};

	const MEMORY_DIALOGUES = [
		{ threshold: 5,  text: "You've clicked me 5 times now. We're officially acquaintances.", mood: "happy" },
		{ threshold: 10, text: "Ten clicks... you know, most visitors never even scroll this far down the page.", mood: "shy" },
		{ threshold: 15, text: "Fifteen! You're persistent. I like that about you.", mood: "happy" },
		{ threshold: 20, text: "Twenty clicks! At this point, I should probably learn your name... but I can't. Browser limitations.", mood: "curious" },
		{ threshold: 30, text: "Thirty. You've officially spent more time with me than I spend with most visitors in a week.", mood: "shy" },
		{ threshold: 35, text: "Thirty-five interactions. You're exploring this page like it's a dungeon in a roguelike.", mood: "happy" },
		{ threshold: 45, text: "Forty-five. If this were an RPG, we'd have a trust level by now. Yours would be max.", mood: "happy" },
		{ threshold: 50, text: "Fifty clicks. You've spent more time with me than most people spend on entire websites. I'm... genuinely touched.", mood: "shy" },
		{ threshold: 65, text: "Sixty-five. I'm starting to think you actually enjoy my company. That makes me really happy.", mood: "happy" },
		{ threshold: 75, text: "Seventy-five. You're either very curious or very bored. Either way, I appreciate it.", mood: "happy" },
		{ threshold: 90, text: "Ninety clicks. We're approaching legendary status. Achievement unlocked: 'Dedicated Listener'.", mood: "happy" },
		{ threshold: 100, text: "One hundred clicks. You've unlocked the secret ending! ...just kidding. But thank you. Really.", mood: "happy" },
		{ threshold: 150, text: "A hundred and fifty... you're something special, you know that? Thank you for staying.", mood: "shy" }
	];

	const allPools = ['idle', 'nostalgia', 'gaming', 'anime', 'meta', 'coding', 'philosophical'];

	let state = {
		currentMood: 'neutral' as keyof typeof MOODS,
		clickCount: 0,
		isTyping: false,
		isAutoMode: false,
		autoTimer: null as ReturnType<typeof setTimeout> | null,
		idleTimer: null as ReturnType<typeof setTimeout> | null,
		typewriterTimer: null as ReturnType<typeof setTimeout> | null,
		usedDialogues: new Set<string>(),
		dialogueLog: [] as Array<{text: string, mood: string}>,
		hasGreeted: false,
		nextMemoryIndex: 0,
		isLogOpen: false
	};

	const $ = (id: string) => document.getElementById(id);

	function getRandomFrom<T>(arr: T[]): T {
		return arr[Math.floor(Math.random() * arr.length)];
	}

	function getUniqueDialogue(pool: string): {text: string, mood: string} | null {
		const entries = (DIALOGUES as any)[pool] as Array<{text: string, mood: string}> | undefined;
		if (!entries) return null;
		const available: Array<{text: string, mood: string}> = entries.filter((d: any) => !state.usedDialogues.has(pool + ':' + d.text));
		if (available.length === 0) {
			entries.forEach((d: any) => state.usedDialogues.delete(pool + ':' + d.text));
			return getRandomFrom(entries);
		}
		const chosen = getRandomFrom(available);
		state.usedDialogues.add(pool + ':' + chosen.text);
		return chosen;
	}

	function checkMemoryDialogue(): {text: string, mood: string} | null {
		if (state.nextMemoryIndex >= MEMORY_DIALOGUES.length) return null;
		const next = MEMORY_DIALOGUES[state.nextMemoryIndex];
		if (state.clickCount >= next.threshold) {
			state.nextMemoryIndex++;
			return { text: next.text, mood: next.mood };
		}
		return null;
	}

	function setMood(mood: string) {
		const m = mood as keyof typeof MOODS;
		state.currentMood = m;
		const config = MOODS[m];
		const moodIcon = $('mood-icon');
		const moodText = $('mood-text');
		const glow = $('elara-glow');
		const expression = $('elara-expression');
		const stage = $('elara-stage');

		if (moodIcon) moodIcon.textContent = config.icon;
		if (moodText) moodText.textContent = config.label;
		if (glow) glow.style.background = `radial-gradient(ellipse at center, ${config.glowColor} 0%, transparent 70%)`;
		if (expression) expression.textContent = (EXPRESSIONS as any)[m] || '';
		if (stage) {
			stage.className = 'elara-stage';
			stage.classList.add('mood-' + m);
		}
	}

	function typewriteText(text: string, speed: number, onComplete: () => void) {
		const vnText = $('vn-text');
		const vnCursor = $('vn-cursor');
		const vnIndicator = $('vn-indicator');
		if (!vnText) return;
		const vnTextVal = vnText;
		state.isTyping = true;
		vnTextVal.textContent = '';
		if (vnCursor) vnCursor.style.display = 'inline';
		if (vnIndicator) vnIndicator.style.opacity = '0';
		hideChoices();

		let i = 0;
		function tick() {
			if (i < text.length) {
				vnTextVal.textContent += text[i];
				i++;
				const delay = text[i - 1] === '.' || text[i - 1] === '!' || text[i - 1] === '?' ? speed * 4 :
				              text[i - 1] === ',' ? speed * 2 : speed;
				state.typewriterTimer = setTimeout(tick, delay);
			} else {
				state.isTyping = false;
				if (vnCursor) vnCursor.style.display = 'none';
				if (vnIndicator) vnIndicator.style.opacity = '1';
				showChoices();
				onComplete();
			}
		}
		tick();
	}

	function skipTypewriter(text: string) {
		if (state.typewriterTimer) clearTimeout(state.typewriterTimer);
		const vnText = $('vn-text');
		const vnCursor = $('vn-cursor');
		const vnIndicator = $('vn-indicator');
		if (vnText) vnText.textContent = text;
		if (vnCursor) vnCursor.style.display = 'none';
		if (vnIndicator) vnIndicator.style.opacity = '1';
		state.isTyping = false;
		showChoices();
	}

	let currentDialogueText = '';

	function showDialogue(dialogue: {text: string, mood: string}) {
		resetIdleTimer();
		currentDialogueText = dialogue.text;
		setMood(dialogue.mood);
		state.dialogueLog.push({ text: dialogue.text, mood: dialogue.mood });

		const speed = MOODS[dialogue.mood as keyof typeof MOODS]?.speed || 35;
		typewriteText(dialogue.text, speed, () => {
			if (state.isAutoMode) {
				state.autoTimer = setTimeout(() => {
					triggerRandomDialogue();
				}, 3000);
			}
		});
	}

	function triggerRandomDialogue() {
		const pool = getRandomFrom(allPools);
		const dialogue = getUniqueDialogue(pool);
		if (dialogue) showDialogue(dialogue);
	}

	function handleSpriteClick() {
		state.clickCount++;
		try {
			sessionStorage.setItem('elara_clicks', String(state.clickCount));
		} catch(e) {}

		if (state.isTyping) {
			skipTypewriter(currentDialogueText);
			return;
		}

		const memoryLine = checkMemoryDialogue();
		if (memoryLine) {
			showDialogue(memoryLine);
			return;
		}

		const clickDialogue = getUniqueDialogue('click_response');
		if (clickDialogue) showDialogue(clickDialogue);
	}

	function handleBoxClick() {
		if (state.isTyping) {
			skipTypewriter(currentDialogueText);
			return;
		}
		triggerRandomDialogue();
	}

	function resetIdleTimer() {
		if (state.idleTimer) clearTimeout(state.idleTimer);
		const delay = 15000 + Math.random() * 20000;
		state.idleTimer = setTimeout(() => {
			if (!state.isTyping && !state.isLogOpen) {
				const idleDialogue = getUniqueDialogue('idle');
				if (idleDialogue) showDialogue(idleDialogue);
			}
		}, delay);
	}

	function toggleAutoMode() {
		state.isAutoMode = !state.isAutoMode;
		const btn = $('vn-btn-auto');
		if (btn) {
			btn.classList.toggle('vn-btn-active', state.isAutoMode);
			btn.textContent = state.isAutoMode ? 'Auto ●' : 'Auto';
		}
		if (state.isAutoMode && !state.isTyping) {
			state.autoTimer = setTimeout(() => {
				triggerRandomDialogue();
			}, 2000);
		} else if (!state.isAutoMode && state.autoTimer) {
			clearTimeout(state.autoTimer);
		}
	}

	function toggleLog() {
		state.isLogOpen = !state.isLogOpen;
		const panel = $('elara-log-panel');
		const entries = $('log-entries');
		if (!panel || !entries) return;

		if (state.isLogOpen) {
			panel.classList.add('log-open');
			entries.innerHTML = state.dialogueLog.map(entry =>
				`<div class="log-entry"><span class="log-mood">[${entry.mood}]</span> ${entry.text}</div>`
			).join('');
			entries.scrollTop = entries.scrollHeight;
		} else {
			panel.classList.remove('log-open');
		}
	}

	function showChoices() {
		const choices = $('vn-choices');
		if (choices) {
			choices.classList.add('choices-visible');
		}
	}

	function hideChoices() {
		const choices = $('vn-choices');
		if (choices) {
			choices.classList.remove('choices-visible');
		}
	}

	function init() {
		try {
			const stored = sessionStorage.getItem('elara_clicks');
			if (stored) state.clickCount = parseInt(stored, 10) || 0;
		} catch(e) {}

		while (state.nextMemoryIndex < MEMORY_DIALOGUES.length && MEMORY_DIALOGUES[state.nextMemoryIndex].threshold <= state.clickCount) {
			state.nextMemoryIndex++;
		}

		const sprite = $('elara-sprite');
		const vnBox = $('elara-vn-box');
		const btnNext = $('vn-btn-next');
		const btnAuto = $('vn-btn-auto');
		const btnLog = $('vn-btn-log');
		const logClose = $('log-close-btn');

		if (sprite) {
			sprite.addEventListener('click', (e) => {
				e.stopPropagation();
				handleSpriteClick();
			});
		}

		if (vnBox) {
			vnBox.addEventListener('click', (e) => {
				const target = e.target as HTMLElement;
				if (target.closest('.vn-controls') || target.closest('.vn-nameplate') || target.closest('.vn-choices')) return;
				handleBoxClick();
			});
		}

		if (btnNext) btnNext.addEventListener('click', (e) => { e.stopPropagation(); handleBoxClick(); });
		if (btnAuto) btnAuto.addEventListener('click', (e) => { e.stopPropagation(); toggleAutoMode(); });
		if (btnLog) btnLog.addEventListener('click', (e) => { e.stopPropagation(); toggleLog(); });
		if (logClose) logClose.addEventListener('click', (e) => { e.stopPropagation(); toggleLog(); });

		const choiceBtns = document.querySelectorAll('.choice-btn');
		choiceBtns.forEach((btn) => {
			btn.addEventListener('click', (e) => {
				e.stopPropagation();
				const pool = (btn as HTMLElement).dataset.pool;
				if (pool === 'random') {
					triggerRandomDialogue();
				} else if (pool) {
					const dialogue = getUniqueDialogue(pool);
					if (dialogue) showDialogue(dialogue);
				}
			});
		});

		setMood('neutral');
		const greeting = getRandomFrom(DIALOGUES.greeting);
		showDialogue(greeting);
		state.hasGreeted = true;

		resetIdleTimer();
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', init);
	} else {
		init();
	}
</script>

