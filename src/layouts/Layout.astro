---
import '../styles/global.css';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>{title}</title>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Outfit:wght@700;900&display=swap" rel="stylesheet">
	</head>
	<body>
		<div class="layout-wrapper">
			<slot />
		</div>
	</body>
</html>

<style>
/* Space reservation for the mobile bottom nav bar */
.layout-wrapper {
	padding-bottom: 70px; /* Base height + gap */
}

@media (min-width: 768px) {
	.layout-wrapper {
		padding-bottom: 0;
	}
}

/* iOS Safe Area Support */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
	.layout-wrapper {
		padding-bottom: calc(70px + env(safe-area-inset-bottom));
	}
	@media (min-width: 768px) {
		.layout-wrapper {
			padding-bottom: 0;
		}
	}
}
</style>
