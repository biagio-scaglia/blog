---
import '../styles/global.css';
import SEO from '../components/SEO.astro';
import CookieConsent from '../components/CookieConsent.astro';

interface Props {
	title: string;
	description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="it">
	<head>
		<meta charset="UTF-8" />
		<SEO title={title} description={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" id="dynamic-favicon" />
		<title>{title}</title>

		<script>
			// Dynamic Favicon Rotation Logic
			document.addEventListener('DOMContentLoaded', () => {
				const favicon = document.getElementById('dynamic-favicon') as HTMLLinkElement;
				if (!favicon) return;

				const icons = [
					'/favicon.svg', // Default
					'/icons/react.svg',
					'/icons/typescript.svg',
					'/icons/nodejs.svg',
					'/icons/csharp.svg',
					'/icons/git.svg',
					'/icons/css.svg',
					'/icons/html.svg'
				];
				
				let currentIndex = 0;

				setInterval(() => {
					currentIndex = (currentIndex + 1) % icons.length;
					const newIcon = icons[currentIndex];
					
					// Force a cache bypass on favicon swap to ensure browsers actually update the tab icon
					// We only do this if it's not the default SVG to not break the original reference
					const stamp = newIcon === '/favicon.svg' ? '' : `?v=${new Date().getTime()}`;
					
					// Changing the href hot-swaps the active favicon
					favicon.href = newIcon + stamp;
				}, 3000); // Swap every 3 seconds
			});
		</script>

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Outfit:wght@700;900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
		<noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;700&family=Outfit:wght@700;900&display=swap"></noscript>
	</head>
	<body>
		<div class="layout-wrapper">
			<slot />
		</div>
		<CookieConsent />
	</body>
</html>

<style>
/* Space reservation for the mobile bottom nav bar */
.layout-wrapper {
	padding-bottom: 70px; /* Base height + gap */
}

@media (min-width: 768px) {
	.layout-wrapper {
		padding-bottom: 0;
	}
}

/* iOS Safe Area Support */
@supports (padding-bottom: env(safe-area-inset-bottom)) {
	.layout-wrapper {
		padding-bottom: calc(70px + env(safe-area-inset-bottom));
	}
	@media (min-width: 768px) {
		.layout-wrapper {
			padding-bottom: 0;
		}
	}
}
</style>
