---
import RetroLayout from '../layouts/RetroLayout.astro';
import Window from '../components/Window.astro';
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import gamingImg from '../assets/gaming_shrine.png';
import moeImg from '../assets/moe_shrine.png';
import JoystickIcon from '../components/icons/JoystickIcon.astro';
import CDIcon from '../components/icons/CDIcon.astro';
import FloppyIcon from '../components/icons/FloppyIcon.astro';
import TVIcon from '../components/icons/TVIcon.astro';
import BadApplePlayer from '../components/BadApplePlayer.astro';
import ElaraCompanion from '../components/ElaraCompanion.astro';
import HeartIcon from '../components/icons/HeartIcon.astro';
---

<RetroLayout title={`Gaming & Anime Shrine - ${SITE_TITLE}`} description="Biagio's personal repository of video games and Moe anime.">
	<div class="shrine-container">
		
		<!-- Row 1: Gaming Shrine -->
		<Window title="gaming_shrine.exe" theme="blue" icon="joystick">
			<div class="shrine-box">
				<h2 class="shrine-heading">
					<JoystickIcon size={16} class="shrine-icon" /> Retro Gaming & RPG Database
				</h2>
				
				<div class="shrine-grid">
					<div class="shrine-image-frame">
						<Image src={gamingImg} alt="Retro Gaming Console" class="shrine-img" width={140} height={140} />
					</div>
					<div class="shrine-text">
						<p>
							Welcome to the gaming sub-node! My passion for video games spans from late-90s PC chiptunes and classic ARPGs to handheld consoles and custom emulation machines.
						</p>
						<p>
							I am also the author and developer of <strong>"Vellum - RPG Companion"</strong>, a mobile assistant designed for tabletop role-playing enthusiasts.
						</p>
					</div>
				</div>

				<h3 class="subsection-title"><FloppyIcon size={12} class="shrine-icon" /> Saved States & Favorites:</h3>
				<table class="shrine-table" width="100%" border="1" cellpadding="5" cellspacing="0">
					<thead>
						<tr class="shrine-table-header">
							<th style="width: 30%;">Platform</th>
							<th style="width: 40%;">Titles / Genres</th>
							<th style="width: 30%;">Status</th>
						</tr>
					</thead>
					<tbody>
						<tr>
							<td><strong>PC</strong></td>
							<td>Diablo II: LOD, Fallout 2, Baldur's Gate II</td>
							<td><span class="status-badge status-grind">Active Grind</span></td>
						</tr>
						<tr>
							<td><strong>Game Boy Advance</strong></td>
							<td>Golden Sun, Pokémon Emerald, Castlevania Aria of Sorrow</td>
							<td><span class="status-badge status-emulated">Emulated / Modded</span></td>
						</tr>
						<tr>
							<td><strong>PlayStation 2</strong></td>
							<td>Silent Hill 2, FFX, Metal Gear Solid 3</td>
							<td><span class="status-badge status-classic">Classic Replays</span></td>
						</tr>
						<tr>
							<td><strong>Handhelds</strong></td>
							<td>PSP-3000, Nintendo DS Lite, Game Boy Color</td>
							<td><span class="status-badge status-hardware">Hardware Modded</span></td>
						</tr>
					</tbody>
				</table>
			</div>
		</Window>

		<!-- Row 2: Moe Shrine -->
		<Window title="moe_shrine.lnk" theme="pink" icon="cd">
			<div class="shrine-box">
				<h2 class="shrine-heading">
					<CDIcon size={16} class="shrine-icon" /> The Moe Anime Sanctuary
				</h2>

				<div class="shrine-grid reverse">
					<div class="shrine-text">
						<p>
							Moe (萌え) represents a unique peak of comfort, character design, and slice-of-life storytelling from the late 90s to the early 2010s.
						</p>
						<p>
							For me, these shows are like digital warm blankets—full of calm, friendship, simple joys, and incredible retro-nostalgic aesthetics.
						</p>
					</div>
					<div class="shrine-image-frame">
						<Image src={moeImg} alt="Moe Anime Art" class="shrine-img" width={140} height={140} />
					</div>
				</div>

				<h3 class="subsection-title"><TVIcon size={12} class="shrine-icon" /> Recommended Watching Logs:</h3>
				<ul class="moe-list">
					<li>
						<strong>Lucky☆Star (2007)</strong> 
						<span class="bubble">Lucky!</span>
						<p class="desc">The ultimate peak of early-Internet otaku culture, MS Paint references, and random discussions about eating chocolate cornets.</p>
					</li>
					<li>
						<strong>Azumanga Daioh (2002)</strong>
						<span class="bubble">Classic</span>
						<p class="desc">The blueprint of all school slice-of-life anime. Relatable character dynamics, absurd humor, and the iconic Chiyo-chan.</p>
					</li>
					<li>
						<strong>Cardcaptor Sakura (1998)</strong>
						<span class="bubble">Mahou Shoujo</span>
						<p class="desc">Beautiful CLAMP artwork, cute outfits, and an unmatched sense of pure passion, discovery, and magic.</p>
					</li>
					<li>
						<strong>K-On! (2009)</strong>
						<span class="bubble">Houkago Tea Time</span>
						<p class="desc">Teatime, cute instruments, and a legendary soundtrack. A masterpiece in character-driven comfort.</p>
					</li>
				</ul>
			</div>
		</Window>

		<!-- Row 3: Elara Desktop Companion -->
		<Window title="elara_companion.exe ~ [Digital Entity]" theme="purple" icon="heart">
			<div class="shrine-box">
				<h2 class="shrine-heading">
					<HeartIcon size={16} class="shrine-icon" /> Desktop Companion Interface
				</h2>
				<p class="elara-intro-text">
					A small digital entity living between the pixels of this page. Click on her or the dialogue box to interact. She might have something to say about old web, retro games, or anime.
				</p>
				<ElaraCompanion />
			</div>
		</Window>

		<!-- Row 4: Bad Apple ASCII Player -->
		<Window title="bad_apple.exe ~ [Gensokyo Terminal]" theme="purple" icon="cd">
			<div class="shrine-box">
				<div class="ba-header-banner">
					<h2 class="shrine-heading">
						<TVIcon size={16} class="shrine-icon" /> Bad Apple!! ~ Real-Time ASCII Render
					</h2>
					<div class="ba-tags">
						<span class="ba-badge badge-purple">★ TOUHOU 04</span>
						<span class="ba-badge badge-green">30 FPS ASCII</span>
						<span class="ba-badge badge-yellow">AUDIO SYNC</span>
					</div>
				</div>
				<p class="ba-description">
					The legendary Touhou PV (Lotus Land Story / Alstroemeria Records) rendered frame-by-frame in ASCII art at 30fps with audio playback.
					Original project credit to <a href="https://github.com/EmirXK/bad_apple" target="_blank" rel="noopener noreferrer">EmirXK/bad_apple</a>.
				</p>
				<BadApplePlayer />
			</div>
		</Window>
	</div>
</RetroLayout>

<style lang="scss">
	@use "../styles/variables" as *;

	.shrine-container {
		display: flex;
		flex-direction: column;
		gap: 20px;
	}

	.shrine-box {
		font-family: $font-verdana;
		font-size: 12px;
		line-height: 1.6;
	}

	.shrine-heading {
		font-family: $font-tahoma;
		font-size: 15px;
		color: $win-blue;
		margin-bottom: 15px;
		display: flex;
		align-items: center;
		gap: 8px;
		border-bottom: 2px solid $win-light-gray;
		padding-bottom: 6px;
	}

	.shrine-icon {
		display: inline-block;
		vertical-align: middle;
	}

	.shrine-grid {
		display: flex;
		gap: 15px;
		margin-bottom: 15px;
		align-items: center;

		&.reverse {
			flex-direction: row-reverse;
		}

		@media (max-width: 600px) {
			flex-direction: column !important;
		}
	}

	.shrine-image-frame {
		@include win95-border-inset;
		background: #000;
		padding: 4px;
		width: 140px;
		height: 140px;
		flex-shrink: 0;
	}

	.shrine-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		image-rendering: pixelated;
	}

	.shrine-text {
		flex-grow: 1;
		p {
			margin: 0 0 10px 0;
			&:last-child {
				margin-bottom: 0;
			}
		}
	}

	.subsection-title {
		font-family: $font-tahoma;
		font-size: 13px;
		color: $win-blue;
		margin: 20px 0 10px 0;
		font-weight: bold;
	}

	.shrine-table {
		font-size: 11px;
		border-collapse: collapse;
		@include win95-border-inset;
		width: 100%;

		.shrine-table-header {
			background: $win-blue;
			color: $win-white;
			font-family: $font-tahoma;
			font-weight: bold;
			text-align: left;
		}

		th, td {
			padding: 6px 10px;
			border: 1px solid $win-dark-gray;
		}

		tr:not(.shrine-table-header) {
			background: $win-white;
			transition: background 0.05s, color 0.05s;

			&:nth-child(even) {
				background: $win-light-gray;
			}

			&:hover {
				background: #000080 !important;
				color: #ffffff;
				
				td {
					color: #ffffff !important;
					strong {
						color: #ffffff !important;
					}
				}
				
				.status-badge {
					border-color: #ffffff;
					background: transparent;
					color: #ffffff;
				}
			}
		}
	}

	.status-badge {
		font-family: $font-tahoma;
		font-size: 9px;
		font-weight: bold;
		padding: 2px 6px;
		border-radius: 2px;
		border: 1px solid;
		display: inline-block;
		text-transform: uppercase;
		white-space: nowrap;

		&.status-grind {
			background: #e2f0cb;
			color: #274e13;
			border-color: #38761d;
		}
		&.status-emulated {
			background: #e0f7fa;
			color: #006064;
			border-color: #00838f;
		}
		&.status-classic {
			background: #fff3cd;
			color: #856404;
			border-color: #ffc107;
		}
		&.status-hardware {
			background: #f3e5f5;
			color: #4a148c;
			border-color: #8e24aa;
		}
	}

	.moe-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: grid;
		grid-template-columns: repeat(2, 1fr);
		gap: 12px;

		@media (max-width: 600px) {
			grid-template-columns: 1fr;
		}

		li {
			background: $win-white;
			@include win95-border-inset;
			padding: 12px;
			margin-bottom: 0;
			position: relative;
			display: flex;
			flex-direction: column;
			gap: 4px;
			transition: transform 0.1s ease-in-out, box-shadow 0.1s ease-in-out;

			&:hover {
				transform: translateY(-2px);
				box-shadow: 3px 3px 0px rgba(0, 0, 0, 0.2);
			}

			strong {
				font-family: $font-tahoma;
				font-size: 13px;
				color: $win-blue;
			}
		}

		li:nth-child(4n+1) .bubble { background: #e0f2f1; color: #004d40; border-color: #009688; }
		li:nth-child(4n+2) .bubble { background: #ffe0b2; color: #e65100; border-color: #ff9800; }
		li:nth-child(4n+3) .bubble { background: #fce4ec; color: #880e4f; border-color: #e91e63; }
		li:nth-child(4n+4) .bubble { background: #e8eaf6; color: #1a237e; border-color: #3f51b5; }

		.bubble {
			font-family: $font-retro-mono;
			font-size: 9px;
			padding: 2px 6px;
			border: 1px solid $win-dark-gray;
			border-radius: 3px;
			font-weight: bold;
			text-transform: uppercase;
			width: fit-content;
			display: inline-block;
			margin-top: 2px;
			margin-bottom: 2px;
		}

		.desc {
			margin: 4px 0 0 0;
			color: #333333;
			font-size: 11px;
			line-height: 1.4;
		}
	}

	.ba-header-banner {
		display: flex;
		justify-content: space-between;
		align-items: center;
		flex-wrap: wrap;
		gap: 10px;
		margin-bottom: 10px;

		.shrine-heading {
			margin-bottom: 0;
			border-bottom: none;
			padding-bottom: 0;
		}
	}

	.ba-tags {
		display: flex;
		gap: 6px;
		align-items: center;
	}

	.ba-badge {
		font-family: $font-tahoma;
		font-size: 9px;
		font-weight: bold;
		padding: 2px 6px;
		border-radius: 2px;
		@include win95-border-outset;
		color: #000;

		&.badge-purple {
			background: $pastel-purple;
			color: #4a148c;
		}

		&.badge-green {
			background: $pastel-green;
			color: #1b5e20;
		}

		&.badge-yellow {
			background: $pastel-yellow;
			color: #f57f17;
		}
	}

	.ba-description {
		font-family: $font-verdana;
		font-size: 11px;
		line-height: 1.6;
		color: #333;
		margin-bottom: 10px;

		a {
			color: $win-blue;
			&:hover {
				color: $win-blue-light;
			}
		}
	}

	.elara-intro-text {
		font-family: $font-verdana;
		font-size: 11px;
		line-height: 1.6;
		color: #333;
		margin-bottom: 12px;
		padding-bottom: 10px;
		border-bottom: 1px dashed $win-dark-gray;
	}
</style>

