---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Featured from '../components/Featured.astro';
import Skills from '../components/Skills.astro';
import Footer from '../components/Footer.astro';
import { Sparkles, Calendar } from 'lucide-astro';

const recentPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);
---

<Layout 
  title="Biagio Scaglia - Blog personale su tech, code e life"
  description="Blog di Biagio Scaglia: appunti su sviluppo software, UX/UI, gaming e crescita nerd."
>
  <main class="mario-container">
    <Header />
    <Hero />
    
    <Featured />
    <Skills />
    
    <!-- Recent Posts Section -->
    <section class="recent-posts-section">
      <div class="section-header">
        <h2 class="heading-galaxy text-gradient section-title">Ultimi Articoli</h2>
        <p class="section-subtitle">Pensieri, tutorial e scoperte dall'Osservatorio.</p>
      </div>
      
      <div class="blog-grid compact">
        {recentPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="blog-card galaxy-card">
            <div class="card-glow-border"></div>
            <div class="blog-card-content">
              <div class="post-meta">
                <span class="badge badge-glow flex-badge">
                  <Calendar size={12} class="calendar-icon" />
                  {post.data.pubDate.toLocaleDateString('it-IT', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </span>
              </div>
              <h3 class="post-title heading-galaxy">{post.data.title}</h3>
            </div>
            
            <div class="read-more compact-read">
              <Sparkles size={14} class="sparkle-icon" />
              <span>Leggi</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>
      
      <div class="view-all-container">
        <a href="/blog" class="galaxy-button secondary">Esplora tutto l'Osservatorio</a>
      </div>
    </section>

    <Footer />
  </main>
</Layout>

<style>
  .recent-posts-section {
    margin: 5rem 0;
  }
  
  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }
  
  .section-title {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  
  .section-subtitle {
    color: var(--text-secondary);
    font-size: 1.1rem;
    font-weight: 300;
  }
  
  .blog-grid.compact {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    max-width: 800px;
    margin: 0 auto;
  }
  
  .blog-card {
    position: relative;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem 2rem;
    text-decoration: none;
    color: inherit;
    transition: transform 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
    z-index: 1;
    overflow: hidden;
  }
  
  .blog-card:hover {
    transform: translateY(-4px);
  }
  
  .card-glow-border {
    position: absolute;
    top: 0;
    left: 0;
    width: 3px;
    height: 100%;
    background: linear-gradient(to bottom, var(--nebula-cyan), var(--nebula-purple));
    box-shadow: 0 0 10px var(--nebula-cyan);
    opacity: 0.5;
    transition: opacity 0.3s ease, width 0.3s ease;
  }
  
  .blog-card:hover .card-glow-border {
    opacity: 1;
    width: 4px;
  }
  
  .blog-card-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    flex-grow: 1;
    z-index: 2;
  }
  
  .flex-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    background: rgba(94, 23, 235, 0.15);
    border: 1px solid rgba(94, 23, 235, 0.3);
    color: var(--starlight);
    padding: 2px 8px;
    border-radius: 4px;
  }
  
  .post-title {
    font-size: 1.4rem;
    line-height: 1.3;
    margin: 0;
    transition: color 0.3s ease, text-shadow 0.3s ease;
  }
  
  .blog-card:hover .post-title {
    color: #fff;
    text-shadow: 0 0 10px rgba(255, 255, 255, 0.2);
  }
  
  .read-more.compact-read {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 500;
    color: var(--nebula-cyan);
    font-size: 0.9rem;
    white-space: nowrap;
    margin-left: 2rem;
    transition: color 0.3s ease;
  }
  
  .blog-card:hover .compact-read {
    color: #fff;
    text-shadow: 0 0 8px rgba(0, 240, 255, 0.8);
  }
  
  .arrow {
    transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
  }
  
  .blog-card:hover .arrow {
    transform: translateX(4px);
  }
  
  .view-all-container {
    display: flex;
    justify-content: center;
    margin-top: 3rem;
  }
  
  @media (max-width: 600px) {
    .blog-card {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
      padding: 1.5rem;
    }
    
    .read-more.compact-read {
      margin-left: 0;
      width: 100%;
      justify-content: flex-end;
    }
    
    .section-title {
      font-size: 2rem;
    }
  }
</style>
