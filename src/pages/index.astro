---
import RetroLayout from '../layouts/RetroLayout.astro';
import Window from '../components/Window.astro';
import LatestPosts from '../components/LatestPosts.astro';
import LatestImages from '../components/LatestImages.astro';
import Guestbook from '../components/Guestbook.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import GlobeIcon from '../components/icons/GlobeIcon.astro';
import FolderIcon from '../components/icons/FolderIcon.astro';
import CameraIcon from '../components/icons/CameraIcon.astro';
import ComputerIcon from '../components/icons/ComputerIcon.astro';
import { Image } from 'astro:assets';
import nyanCat from '../assets/nyan-cat.gif';
---

<RetroLayout title={`${SITE_TITLE} - Official Site of Biagio Scaglia`} description={SITE_DESCRIPTION}>
	<Window title="welcome.txt" theme="windows" icon="computer">
		<div class="welcome-box">
			<h2 class="welcome-heading">
				<ComputerIcon size={16} /> 
				<span>Welcome to Biagio's cyber portal!</span> 
				<ComputerIcon size={16} />
			</h2>
			<p>
				Greetings, wanderer! You have landed on my personal databank. I built this space to host my software projects, retrocomputing experiments, anime reviews, and my thoughts on web development and design.
			</p>
			<p>
				I'm Biagio Scaglia, a full-stack developer (React, .NET, React Native) and UX/UI designer. Here you'll find technical logs, screenshots of my work, and deep dives into my creations, including my tabletop RPG app, <strong>Vellum - RPG Companion</strong>.
			</p>
			<div class="system-status-table">
				<table width="100%" border="1" cellpadding="4" cellspacing="0" class="retro-status-table">
					<tr class="table-header">
						<th colspan="2"><GlobeIcon size={12} class="title-icon" /> Biagio Cyberspace Node Statistics</th>
					</tr>
					<tr>
						<td><strong>Webmaster:</strong></td>
						<td>Biagio Scaglia</td>
					</tr>
					<tr>
						<td><strong>Stack:</strong></td>
						<td>Astro + TypeScript + SCSS</td>
					</tr>
					<tr>
						<td><strong>Current Projects:</strong></td>
						<td>Vellum - RPG Companion</td>
					</tr>
					<tr>
						<td><strong>Last Updated:</strong></td>
						<td>July 2, 2026</td>
					</tr>
				</table>
			</div>
		</div>
	</Window>


	<Window title="personal_logs.exe" theme="blue" icon="notepad">
		<h2 class="section-title"><FolderIcon size={14} class="title-icon" /> Latest Diary Entries</h2>
		<LatestPosts />
	</Window>

	<Window title="image_dump" theme="green" icon="camera">
		<h2 class="section-title"><CameraIcon size={14} class="title-icon" /> Latest Captured Visuals</h2>
		<p class="section-subtitle">A collection of snaps from my digital camera and sprite edits.</p>
		<LatestImages />
	</Window>

	<Window title="guestbook.app" theme="purple" icon="guestbook">
		<Guestbook />
	</Window>

	<Window title="nyan.exe" theme="rainbow" icon="joystick">
		<div class="nyan-box">
			<Image src={nyanCat} alt="Nyan Cat!" class="nyan-gif" />
			<p class="nyan-text">
				~ NYAN NYAN NYAN NYAN NYAN ~
			</p>
		</div>
	</Window>
</RetroLayout>

<style lang="scss">
	@use "../styles/variables" as *;

	.welcome-box {
		font-family: $font-verdana;
		font-size: 12px;
		line-height: 1.4;
	}

	.welcome-heading {
		color: #800080;
		text-align: center;
		margin-bottom: 12px;
		font-size: 16px;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
	}

	.system-status-table {
		margin-top: 15px;
	}

	.retro-status-table {
		border-collapse: collapse;
		border: 1px solid $win-dark-gray;
		font-family: $font-retro-mono;
		font-size: 11px;
		width: 100%;

		.table-header {
			background: $win-blue;
			color: $win-white;
			font-family: $font-tahoma;
			font-size: 11px;
			font-weight: bold;
		}

		td, th {
			border: 1px solid $win-dark-gray;
			padding: 4px 8px;
		}

		tr:not(.table-header) {
			background: #ffffff;
			transition: background 0.05s, color 0.05s;

			&:nth-child(even) {
				background: $win-light-gray;
			}

			&:hover {
				background: #000080 !important;
				color: #ffffff;

				td {
					color: #ffffff !important;
					strong {
						color: #ffffff !important;
					}
				}
			}
		}
	}

	.section-title {
		font-family: $font-tahoma;
		font-size: 14px;
		color: $win-blue;
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.title-icon {
		display: inline-block;
		vertical-align: middle;
	}

	.section-subtitle {
		font-family: $font-verdana;
		font-size: 11px;
		color: #555555;
		margin-bottom: 12px;
	}

	.nyan-box {
		text-align: center;
		padding: 10px;
	}

	.nyan-gif {
		image-rendering: pixelated;
		width: 100%;
		max-width: 400px;
		height: auto;
		display: block;
		margin: 0 auto 12px auto;
		mix-blend-mode: multiply;
	}

	.nyan-text {
		font-family: $font-retro-mono;
		font-size: 16px;
		color: #ff00ff;
		text-shadow: 1px 1px 0 #000;
		font-weight: bold;
		margin: 0;
		animation: rainbow-text 4s infinite linear;
	}

	.preview-browser-box {
		font-family: $font-verdana;
		font-size: 11px;
	}

	.browser-address-bar {
		display: flex;
		align-items: center;
		gap: 6px;
		background: $win-gray;
		padding: 4px 6px;
		margin-bottom: 8px;
		@include win95-border-outset;
	}

	.address-label {
		font-family: $font-tahoma;
		font-weight: bold;
		font-size: 11px;
		color: #333;
	}

	.address-input {
		flex-grow: 1;
		font-family: $font-retro-mono;
		font-size: 11px;
		padding: 2px 6px;
		background: #ffffff;
		color: #000080;
		@include win95-border-inset;
		outline: none;
	}

	.address-go-btn {
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		color: #000;
		background: $win-gray;
		padding: 2px 8px;
		text-decoration: none;
		@include win95-border-outset;

		&:active {
			@include win95-border-inset;
		}

		&:hover {
			color: #0000ff;
		}
	}

	.preview-frame-container {
		position: relative;
		width: 100%;
		height: 240px;
		background: #000;
		@include win95-border-inset;
		overflow: hidden;
	}

	.preview-iframe {
		width: 100%;
		height: 100%;
		border: none;
		background: #ffffff;
	}

	.preview-fallback {
		display: none;
	}

	.preview-caption {
		margin-top: 6px;
		font-size: 10px;
		color: $win-dark-gray;
		text-align: center;

		code {
			background: #e0e0e0;
			padding: 1px 4px;
			color: #800080;
		}
	}

	@keyframes rainbow-text {
		0% { color: #ff3333; }
		17% { color: #ffae19; }
		33% { color: #ffff33; }
		50% { color: #33ff33; }
		67% { color: #3333ff; }
		83% { color: #8a33ff; }
		100% { color: #ff3333; }
	}
</style>
