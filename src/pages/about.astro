<script>
	document.querySelectorAll('.kaomoji-item').forEach(item => {
		item.addEventListener('click', () => {
			const text = item.textContent || '';
			navigator.clipboard.writeText(text).then(() => {
				const toast = document.getElementById('kaomoji-toast');
				if (!toast) return;
				toast.textContent = `Copied: ${text}`;
				toast.classList.add('toast-visible');
				setTimeout(() => {
					toast.classList.remove('toast-visible');
				}, 1200);
			}).catch(() => {
				const textarea = document.createElement('textarea');
				textarea.value = text;
				textarea.style.position = 'fixed';
				textarea.style.opacity = '0';
				document.body.appendChild(textarea);
				textarea.select();
				document.execCommand('copy');
				document.body.removeChild(textarea);

				const toast = document.getElementById('kaomoji-toast');
				if (!toast) return;
				toast.textContent = `Copied: ${text}`;
				toast.classList.add('toast-visible');
				setTimeout(() => {
					toast.classList.remove('toast-visible');
				}, 1200);
			});
		});
	});
</script>

<style lang="scss">
	@use "../styles/variables" as *;

	.about-container {
		font-family: $font-verdana;
		font-size: 12px;
		line-height: 1.5;
	}

	.bio-intro {
		display: flex;
		gap: 15px;
		margin-bottom: 20px;
		align-items: flex-start;
	}

	.bio-avatar-frame {
		@include win95-border-inset;
		background: #000;
		padding: 4px;
		width: 100px;
		height: 100px;
		flex-shrink: 0;
	}

	.bio-avatar {
		width: 100%;
		height: 100%;
		object-fit: cover;
		image-rendering: pixelated;
	}

	.bio-desc {
		flex-grow: 1;

		p {
			margin: 0 0 10px 0;

			&:last-child {
				margin-bottom: 0;
			}
		}
	}

	.bio-table {
		border-collapse: collapse;
		border: 1px solid $win-dark-gray;
		font-size: 11px;
		margin-bottom: 20px;

		.bio-header {
			background: #ff69b4;
			color: #ffffff;
			font-family: $font-tahoma;
			font-size: 11px;
			font-weight: bold;
		}

		td, th {
			border: 1px solid $win-dark-gray;
			padding: 5px 8px;
		}
	}

	.about-title {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.about-subheading {
		font-family: $font-tahoma;
		font-size: 13px;
		color: $win-blue;
		border-bottom: 1px dashed $win-dark-gray;
		padding-bottom: 3px;
		margin-bottom: 8px;
		display: flex;
		align-items: center;
		gap: 6px;
	}

	.title-icon {
		display: inline-block;
		vertical-align: middle;
	}
</style>
