---
import RetroLayout from '../layouts/RetroLayout.astro';
import Window from '../components/Window.astro';
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import profilePic from '../assets/avatar.png';
import ComputerIcon from '../components/icons/ComputerIcon.astro';
import NotepadIcon from '../components/icons/NotepadIcon.astro';
import GlobeIcon from '../components/icons/GlobeIcon.astro';

const faqSchema = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	"mainEntity": [
		{
			"@type": "Question",
			"name": "What is Biagio Scaglia's primary software development expertise?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Biagio is a Full Stack Developer and UX/UI Designer specialized in React, TypeScript, .NET, and React Native. He designs and codes systems end-to-end, combining modern performance with robust user experiences."
			}
		},
		{
			"@type": "Question",
			"name": "What is the app Vellum - RPG Companion?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Vellum - RPG Companion is a mobile utility application designed and developed by Biagio Scaglia to act as a digital character sheet and campaign assistant for tabletop role-playing games (TTRPGs)."
			}
		},
		{
			"@type": "Question",
			"name": "How does this portal align with modern web standard optimizations?",
			"acceptedAnswer": {
				"@type": "Answer",
				"text": "Although styled like an early-2000s personal site, it leverages Astro static generation, full responsive SCSS layouts, dynamic JSON-LD metadata for search engines and generative AI bots, and automated responsive image conversion (WebP) to guarantee near-instant loading times."
			}
		}
	]
};
---


<RetroLayout title={`About Me - ${SITE_TITLE}`} description="Biography of the webmaster">
	<script type="application/ld+json" is:inline set:html={JSON.stringify(faqSchema)} />
	<Window title="about_webmaster.txt" theme="pink" icon="computer">
		<div class="about-container">
			<h2 class="about-title"><ComputerIcon size={18} /> Greetings, cyber wanderer!</h2>
			<div class="bio-intro">
				<div class="bio-avatar-frame">
					<Image src={profilePic} alt="Astro Webmaster" class="bio-avatar" width={100} height={100} />
				</div>
				<div class="bio-desc">
					<p>
						Welcome! I am the lead operator and designer of Biagio Cyberspace. I have been building sites, tinkering with hardware, and writing code since 2004.
					</p>
					<p>
						This site is my digital sandbox, built to preserve the nostalgic essence of the early web while leveraging modern static site generation with Astro.
					</p>
				</div>
			</div>

			<table class="bio-table" width="100%" border="1" cellpadding="5" cellspacing="0">
				<tr class="bio-header">
					<th colspan="2"><NotepadIcon size={12} class="title-icon" /> User Profile Database</th>
				</tr>
				<tr>
					<td style="width: 30%;"><strong>Alias:</strong></td>
					<td>Astro_Wanderer</td>
				</tr>
				<tr>
					<td><strong>Operating Base:</strong></td>
					<td>Rome, Italy</td>
				</tr>
				<tr>
					<td><strong>First Computer:</strong></td>
					<td>Pentium III 800MHz / 128MB RAM / Win98 SE</td>
				</tr>
				<tr>
					<td><strong>Favorite Editors:</strong></td>
					<td>Notepad, Vim, Astro Engine</td>
				</tr>
				<tr>
					<td><strong>Interests:</strong></td>
					<td>Retro console modding, MIDI synth music, pixel art, cyberpunk lore</td>
				</tr>
			</table>

			<h3 class="about-subheading"><ComputerIcon size={14} /> Hardware Specs</h3>
			<p>
				Currently writing from a custom beige-tower build running modern tooling, outputting to dual CRT monitors for the ultimate low-resolution testing experience!
			</p>

			<h3 class="about-subheading"><GlobeIcon size={14} /> Colophon & Web Standards</h3>
			<p>
				This portal conforms strictly to the **HTML 4.01 Transitional** and **CSS 2.0** layout models. It is built to load instantly over a 56k dial-up connection. Generates static HTML via modern tools (Astro) with zero tracking scripts, zero cookie consent overlays, and absolute compatibility with legacy clients. 
			</p>

			<h3 class="about-subheading"><NotepadIcon size={14} /> FAQ & System Inquiries</h3>
			<div class="faq-section" style="margin-top: 10px; display: flex; flex-direction: column; gap: 12px; margin-bottom: 10px;">
				<div class="faq-item">
					<p style="margin: 0; font-weight: bold; color: #800080;">Q: What is Biagio Scaglia's primary software development expertise?</p>
					<p style="margin: 4px 0 0 0; color: #333;">A: Biagio is a Full Stack Developer and UX/UI Designer specialized in React, TypeScript, .NET, and React Native. He designs and codes systems end-to-end, combining modern performance with robust user experiences.</p>
				</div>
				<div class="faq-item">
					<p style="margin: 0; font-weight: bold; color: #800080;">Q: What is the app "Vellum - RPG Companion"?</p>
					<p style="margin: 4px 0 0 0; color: #333;">A: Vellum - RPG Companion is a mobile utility application designed and developed by Biagio Scaglia to act as a digital character sheet and campaign assistant for tabletop role-playing games (TTRPGs).</p>
				</div>
				<div class="faq-item">
					<p style="margin: 0; font-weight: bold; color: #800080;">Q: How does this portal align with modern web standard optimizations?</p>
					<p style="margin: 4px 0 0 0; color: #333;">A: Although styled like an early-2000s personal site, it leverages Astro static generation, full responsive SCSS layouts, dynamic JSON-LD metadata for search engines and generative AI bots, and automated responsive image conversion (WebP) to guarantee near-instant loading times.</p>
				</div>
			</div>
		</div>
	</Window>

