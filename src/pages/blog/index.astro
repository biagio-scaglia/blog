---
import { getCollection } from 'astro:content';
import RetroLayout from '../../layouts/RetroLayout.astro';
import Window from '../../components/Window.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<RetroLayout title={`Blog Directory - ${SITE_TITLE}`} description="Browse the diary logs of the Astro-Webmaster">
	<div class="active-filter-alert" id="filter-alert" style="display: none;">
		<div class="alert-box">
			<span class="alert-text">Active Filter: <strong id="filter-type">None</strong> = <span id="filter-value">None</span></span>
			<a href="/blog" class="clear-btn">[ Show All Logs ]</a>
		</div>
	</div>

	<Window title="blog_directory.exe" theme="blue">
		<div class="blog-dir-header">
			<h2>📂 diary_logs/</h2>
			<p>Double click or click a log file to view the entries. Current index contains {posts.length} entries.</p>
		</div>

		<div class="posts-container">
			{posts.map((post) => {
				const year = post.data.pubDate.getFullYear();
				const month = String(post.data.pubDate.getMonth() + 1).padStart(2, '0');
				const archiveKey = `${year}-${month}`;
				
				return (
					<div 
						class="post-wrapper" 
						data-category={post.data.category || 'General'}
						data-archive={archiveKey}
						data-tags={post.data.tags ? post.data.tags.join(',') : ''}
					>
						<ArticleCard post={post} />
					</div>
				);
			})}
		</div>
	</Window>
</RetroLayout>

<script>
	const params = new URLSearchParams(window.location.search);
	const category = params.get('category');
	const tag = params.get('tag');
	const archive = params.get('archive');
	
	const alertDiv = document.getElementById('filter-alert');
	const filterTypeSpan = document.getElementById('filter-type');
	const filterValueSpan = document.getElementById('filter-value');
	const postWrappers = document.querySelectorAll('.post-wrapper');

	if (category || tag || archive) {
		if (alertDiv && filterTypeSpan && filterValueSpan) {
			alertDiv.style.display = 'block';
			if (category) {
				filterTypeSpan.textContent = 'Category';
				filterValueSpan.textContent = category;
			} else if (tag) {
				filterTypeSpan.textContent = 'Tag';
				filterValueSpan.textContent = '#' + tag;
			} else if (archive) {
				filterTypeSpan.textContent = 'Archive Month';
				filterValueSpan.textContent = archive;
			}
		}

		postWrappers.forEach((wrapper) => {
			if (!(wrapper instanceof HTMLElement)) return;
			let match = false;
			if (category && wrapper.dataset.category === category) {
				match = true;
			} else if (tag) {
				const tags = wrapper.dataset.tags ? wrapper.dataset.tags.split(',') : [];
				if (tags.includes(tag)) {
					match = true;
				}
			} else if (archive && wrapper.dataset.archive === archive) {
				match = true;
			}

			if (match) {
				wrapper.style.display = 'block';
			} else {
				wrapper.style.display = 'none';
			}
		});
	}
</script>

<style lang="scss">
	@use "../../styles/variables" as *;

	.blog-dir-header {
		font-family: $font-tahoma;
		border-bottom: 2px groove #fff;
		margin-bottom: 15px;
		padding-bottom: 8px;

		h2 {
			color: $win-blue;
			font-size: 16px;
			margin: 0;
		}

		p {
			font-size: 11px;
			color: #555;
			margin: 4px 0 0 0;
		}
	}

	.active-filter-alert {
		margin-bottom: 12px;
	}

	.alert-box {
		@include win95-border-outset;
		background: #ffffcc;
		border: 1px dashed #ff9900;
		padding: 8px 12px;
		display: flex;
		justify-content: space-between;
		align-items: center;
		font-family: $font-verdana;
		font-size: 11px;
	}

	.alert-text {
		color: #cc6600;
	}

	.clear-btn {
		font-weight: bold;
		color: #0000ff;
		text-decoration: none;

		&:hover {
			color: #ff0000;
			text-decoration: underline;
		}
	}

	.posts-container {
		display: flex;
		flex-direction: column;
	}
</style>
