---
import { getCollection, render } from 'astro:content';
import RetroLayout from '../../layouts/RetroLayout.astro';
import Window from '../../components/Window.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).sort(
		(a, b) => a.data.pubDate.valueOf() - b.data.pubDate.valueOf(),
	);
	return posts.map((post, index) => ({
		params: { slug: post.id },
		props: {
			post,
			prev: index > 0 ? posts[index - 1] : null,
			next: index < posts.length - 1 ? posts[index + 1] : null,
		},
	}));
}

const { post, prev, next } = Astro.props;
const { Content } = await render(post);

const coverImage = post.data.cover || post.data.heroImage;
const galleryImages = post.data.gallery || [];

const postUrl = new URL(Astro.url.pathname, Astro.site || 'https://biagioscaglia.dev').toString();
const authorId = Astro.site ? `${Astro.site.toString()}#person` : 'https://biagioscaglia.dev#person';

const blogPostSchema = {
	"@context": "https://schema.org",
	"@type": "BlogPosting",
	"@id": `${postUrl}#entry`,
	"isPartOf": {
		"@type": "WebPage",
		"@id": postUrl,
		"url": postUrl,
		"name": post.data.title
	},
	"headline": post.data.title,
	"description": post.data.description,
	"image": coverImage ? (typeof coverImage === 'string' ? coverImage : coverImage.src) : undefined,
	"datePublished": post.data.pubDate.toISOString(),
	"dateModified": post.data.updatedDate ? post.data.updatedDate.toISOString() : post.data.pubDate.toISOString(),
	"author": {
		"@type": "Person",
		"@id": authorId,
		"name": "Biagio Scaglia",
		"url": Astro.site ? Astro.site.toString() : 'https://biagioscaglia.dev'
	},
	"publisher": {
		"@type": "Person",
		"@id": authorId,
		"name": "Biagio Scaglia"
	},
	"keywords": post.data.tags ? post.data.tags.join(', ') : undefined
};
---

<RetroLayout title={`${post.data.title} - Retro-Net`} description={post.data.description}>
	<script type="application/ld+json" is:inline set:html={JSON.stringify(blogPostSchema)} />
	<Window title={`view_log.sys - ${post.id}`} theme="windows">
		<article class="retro-post">
			<div class="post-metadata">
				<span class="post-category">[{post.data.category}]</span>
				<span class="post-date">
					📅 Logged on: <FormattedDate date={post.data.pubDate} />
				</span>
			</div>
			
			<h1 class="post-title">{post.data.title}</h1>
			<hr class="post-divider" />

			{coverImage && (
				<div class="post-cover-frame">
					<Image src={coverImage} alt={post.data.title} class="post-cover-img" width={800} />
				</div>
			)}

			<div class="post-body-content">
				<Content />
			</div>

			{galleryImages.length > 0 && (
				<div class="post-gallery-section">
					<h3 class="gallery-title">📷 Post Photo Gallery</h3>
					<div class="post-gallery-grid">
						{galleryImages.map((img: any) => (
							<div class="gallery-frame">
								<Image src={img} alt="Gallery item" class="gallery-img" width={300} height={300} />
							</div>
						))}
					</div>
				</div>
			)}

			<div class="post-signature">
				<p class="signature-line">---</p>
				<p class="signature-content">
					<em>Logged by <strong>Biagio Scaglia</strong> (Webmaster)</em><br />
					contact [at] biagioscaglia [dot] dev
				</p>
			</div>

			<div class="post-tags-list">
				{post.data.tags.map((tag: string) => (
					<a href={`${import.meta.env.BASE_URL}blog?tag=${tag}`} class="tag-badge">#{tag}</a>
				))}
			</div>

			<hr class="post-divider" />

			<div class="post-navigation-row">
				<div class="nav-prev">
					{prev ? (
						<a href={`${import.meta.env.BASE_URL}blog/${prev.id}/`} class="nav-btn">
							« Previous Log: {prev.data.title}
						</a>
					) : (
						<span class="nav-btn-disabled">« First Entry</span>
					)}
				</div>
				<div class="nav-next">
					{next ? (
						<a href={`${import.meta.env.BASE_URL}blog/${next.id}/`} class="nav-btn">
							Next Log: {next.data.title} »
						</a>
					) : (
						<span class="nav-btn-disabled">Last Entry »</span>
					)}
				</div>
			</div>
		</article>
	</Window>
</RetroLayout>

<style lang="scss">
	@use "../../styles/variables" as *;

	.retro-post {
		font-family: $font-verdana;
		font-size: 13px;
		line-height: 1.6;
	}

	.post-metadata {
		display: flex;
		justify-content: space-between;
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		color: $win-dark-gray;
		margin-bottom: 6px;
	}

	.post-category {
		color: $win-blue;
	}

	.post-title {
		font-family: $font-tahoma;
		font-size: 20px;
		font-weight: bold;
		color: $win-blue;
		margin: 0 0 10px 0;
	}

	.post-divider {
		border: none;
		height: 2px;
		@include win95-border-inset;
		margin: 12px 0;
	}

	.post-cover-frame {
		@include win95-border-inset;
		background: #000;
		padding: 4px;
		margin-bottom: 15px;
		max-height: 300px;
		overflow: hidden;
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.post-cover-img {
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.post-body-content {
		color: $win-text;
		
		p {
			margin-bottom: 12px;
		}

		a {
			color: #0000ee;
			text-decoration: underline;

			&:hover {
				color: #ff0000;
			}
		}

		ul, ol {
			margin-left: 20px;
			margin-bottom: 12px;
		}
	}

	.post-signature {
		margin-top: 20px;
		margin-bottom: 15px;
		padding: 10px;
		background: $win-light-gray;
		@include win95-border-inset;
		font-family: $font-tahoma;
		font-size: 11px;

		.signature-line {
			margin: 0 0 5px 0;
			color: $win-dark-gray;
		}

		.signature-content {
			margin: 0;
			color: $win-text;
			line-height: 1.4;
		}
	}

	.post-gallery-section {
		margin-top: 25px;
		background: #f7f7f7;
		@include win95-border-inset;
		padding: 10px;
	}

	.gallery-title {
		font-family: $font-tahoma;
		font-size: 12px;
		color: $win-blue;
		margin-bottom: 8px;
		border-bottom: 1px solid $win-dark-gray;
		padding-bottom: 2px;
	}

	.post-gallery-grid {
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		gap: 8px;
	}

	.gallery-frame {
		background: #ffffff;
		border: 1px solid #ccc;
		padding: 4px;
	}

	.gallery-img {
		width: 100%;
		aspect-ratio: 1;
		object-fit: cover;
		display: block;
	}

	.post-tags-list {
		display: flex;
		flex-wrap: wrap;
		gap: 6px;
		margin-top: 15px;
	}

	.tag-badge {
		font-family: $font-retro-mono;
		font-size: 11px;
		color: #555555;
		background: #eeeeee;
		@include win95-border-inset;
		padding: 2px 6px;
		text-decoration: none;

		&:hover {
			color: #ff0000;
			background: #ffffe0;
		}
	}

	.post-navigation-row {
		display: flex;
		justify-content: space-between;
		gap: 10px;
		margin-top: 15px;
	}

	.nav-prev, .nav-next {
		flex: 1;
	}

	.nav-next {
		text-align: right;
	}

	.nav-btn {
		display: inline-block;
		@include win95-border-outset;
		background: $win-gray;
		color: $win-text;
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		padding: 5px 10px;
		text-decoration: none;
		max-width: 100%;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;

		&:hover {
			background: $win-light-gray;
		}

		&:active {
			border-color: $win-dark-gray $win-white $win-white $win-dark-gray;
			padding: 6px 9px 4px 11px;
		}
	}

	.nav-btn-disabled {
		display: inline-block;
		@include win95-border-inset;
		background: $win-gray;
		color: $win-dark-gray;
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		padding: 5px 10px;
		max-width: 100%;
		white-space: nowrap;
		overflow: hidden;
		text-overflow: ellipsis;
		user-select: none;
	}
</style>
