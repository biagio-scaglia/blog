---
import RetroLayout from '../layouts/RetroLayout.astro';
import Window from '../components/Window.astro';
import { SITE_TITLE } from '../consts';
import { Image } from 'astro:assets';
import fdLogo from '../assets/fd logo.jpeg';
import HeartIcon from '../components/icons/HeartIcon.astro';
import GlobeIcon from '../components/icons/GlobeIcon.astro';
import ComputerIcon from '../components/icons/ComputerIcon.astro';
---

<RetroLayout title={`Contributors - ${SITE_TITLE}`} description="A section dedicated to those who believed in me and in whom I place my trust.">
	<Window title="contributors.lnk ~ [Special Thanks]" theme="purple" icon="globe">
		<div class="contributors-container">
			<h2 class="page-title">
				<HeartIcon size={20} class="heart-pulse" /> 
				<span>Credits & Contributors</span> 
				<HeartIcon size={20} class="heart-pulse" />
			</h2>
			
			<p class="intro-description">
				A section dedicated to those who believed in me and in whom I place my trust.
			</p>
			
			<hr class="retro-divider" />
			
			<div class="contributors-grid">
				<!-- Contributor Card: FDeveloper -->
				<div class="contributor-card">
					<div class="card-left">
						<div class="avatar-frame">
							<Image src={fdLogo} alt="FDeveloper Logo" class="contributor-avatar" width={80} height={80} />
						</div>
					</div>
					<div class="card-right">
						<h3 class="contributor-name">FDeveloper</h3>
						<p class="contributor-role">Independent Web Creator & Developer</p>
						<p class="contributor-bio">
							For believing in this project from the very beginning, for constant support, and for sharing the same sincere passion for the free and independent web.
						</p>
						<div class="button-row">
							<a href="https://fdeveloperweb.vercel.app" target="_blank" rel="noopener noreferrer" class="retro-btn">
								<GlobeIcon size={12} class="btn-icon" /> 
								<span>open_link.exe</span>
							</a>
						</div>
					</div>
				</div>
			</div>
			
			<div class="system-footer-box">
				<ComputerIcon size={12} class="footer-icon" />
				<span>Node Admin: biagio.scaglia.dev | Trust Network Verified</span>
			</div>
		</div>
	</Window>
</RetroLayout>

<style lang="scss">
	@use "../styles/variables" as *;

	.contributors-container {
		font-family: $font-verdana;
		font-size: 13px;
		color: $win-text;
		line-height: 1.5;
		padding: 5px;
	}

	.page-title {
		font-family: $font-tahoma;
		font-size: 20px;
		color: $win-blue;
		text-align: center;
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		margin-bottom: 15px;

		.heart-pulse {
			animation: pulse 1.5s infinite ease-in-out;
		}
	}

	@keyframes pulse {
		0%, 100% { transform: scale(1); }
		50% { transform: scale(1.15); }
	}

	.intro-description {
		font-family: $font-tahoma;
		font-size: 12px;
		font-style: italic;
		text-align: center;
		color: #555555;
		background: #ffffff;
		border: 1px solid $win-dark-gray;
		padding: 10px;
		margin-bottom: 20px;
		@include win95-border-inset;
	}

	.retro-divider {
		border: none;
		height: 2px;
		@include win95-border-inset;
		margin-bottom: 20px;
	}

	.contributors-grid {
		display: flex;
		flex-direction: column;
		gap: 20px;
		margin-bottom: 20px;
	}

	.contributor-card {
		@include win95-border-outset;
		background: $win-light-gray;
		padding: 15px;
		display: flex;
		gap: 15px;
		transition: all 0.1s ease-in-out;

		&:hover {
			background: #dadada;
		}

		@media (max-width: 600px) {
			flex-direction: column;
			align-items: center;
			text-align: center;
		}
	}

	.card-left {
		flex-shrink: 0;
	}

	.avatar-frame {
		@include win95-border-inset;
		background: #000;
		padding: 4px;
		width: 90px;
		height: 90px;
		display: flex;
		justify-content: center;
		align-items: center;
		overflow: hidden;
	}

	.contributor-avatar {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		image-rendering: auto;
	}

	.card-right {
		flex-grow: 1;
	}

	.contributor-name {
		font-family: $font-tahoma;
		font-size: 16px;
		font-weight: bold;
		color: $win-blue;
		margin: 0 0 4px 0;
	}

	.contributor-role {
		font-family: $font-tahoma;
		font-size: 11px;
		color: $win-dark-gray;
		font-weight: bold;
		margin: 0 0 10px 0;
		text-transform: uppercase;
		letter-spacing: 0.5px;
	}

	.contributor-bio {
		font-size: 12px;
		margin: 0 0 15px 0;
		color: $win-text;
	}

	.button-row {
		display: flex;
		gap: 10px;

		@media (max-width: 600px) {
			justify-content: center;
		}
	}

	.retro-btn {
		display: inline-flex;
		align-items: center;
		gap: 6px;
		@include win95-border-outset;
		background: $win-gray;
		color: $win-text;
		font-family: $font-tahoma;
		font-size: 11px;
		font-weight: bold;
		padding: 5px 12px;
		text-decoration: none;
		user-select: none;

		&:hover {
			background: $win-light-gray;
			color: $win-text;
			text-decoration: none;
		}

		&:active {
			border-color: $win-dark-gray $win-white $win-white $win-dark-gray;
			padding: 6px 11px 4px 13px;
		}
	}

	.btn-icon {
		display: inline-block;
	}

	.system-footer-box {
		@include win95-border-inset;
		background: #ffffff;
		padding: 6px 10px;
		font-family: $font-retro-mono;
		font-size: 10px;
		color: #008000;
		display: flex;
		align-items: center;
		gap: 6px;
		font-weight: bold;
	}
</style>
